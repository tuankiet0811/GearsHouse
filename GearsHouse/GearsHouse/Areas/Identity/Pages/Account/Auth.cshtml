@page
@{
    Layout = null;

    var error = TempData["AuthError"] as string;
    var tab = TempData["AuthTab"] as string; // "login" | "register"
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập / Đăng ký</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            margin: 0;
            height: 100vh;
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            position: relative;
            width: 900px;
            height: 520px;
            background: #1a1f29;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }

        .form-container {
            position: absolute;
            width: 50%;
            height: 100%;
            padding: 50px;
            transition: all 0.6s ease-in-out;
        }

        .login-container {
            left: 0;
        }

        .register-container {
            left: 50%;
            opacity: 0;
        }

        .container.active .login-container {
            transform: translateX(-100%);
            opacity: 0;
        }

        .container.active .register-container {
            transform: translateX(-100%);
            opacity: 1;
        }

        .overlay {
            position: absolute;
            right: 0;
            width: 50%;
            height: 100%;
            background: linear-gradient(135deg, #ff5722, #ff784e);
            transition: transform 0.6s ease-in-out;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #fff;
            padding: 40px;
            text-align: center;
        }

        .container.active .overlay {
            transform: translateX(-100%);
        }

        h2 {
            color: #ff5722;
            margin-bottom: 20px;
            text-align: center;
        }

        .overlay h2 {
            color: #fff;
        }

        p {
            font-size: 15px;
            line-height: 1.6;
        }

        input {
            width: 100%;
            padding: 12px 14px;
            margin-bottom: 14px;
            border-radius: 10px;
            border: 1.5px solid #3a4550;
            background: #121621;
            color: #fff;
            font-size: 14px;
        }

            input:focus {
                outline: none;
                border-color: #ff5722;
                box-shadow: 0 0 8px #ff5722;
            }

        button {
            width: 100%;
            padding: 12px;
            border-radius: 12px;
            border: none;
            background: #ff5722;
            color: #fff;
            font-weight: bold;
            cursor: pointer;
            margin-top: 5px;
        }

            button:hover {
                background: #e64a19;
            }

        .ghost-btn {
            background: transparent;
            border: 2px solid #fff;
            margin-top: 20px;
        }

            .ghost-btn:hover {
                background: rgba(255,255,255,0.15);
            }

        .error {
            color: #ff6b6b;
            text-align: center;
            margin-bottom: 15px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container @(tab == "register" ? "active" : "")" id="container">

        <!-- LOGIN -->
        <div class="form-container login-container">
            <h2><i class="fas fa-sign-in-alt"></i> Đăng nhập</h2>

            @if (tab == "login" && error != null)
            {
                <div class="error">@error</div>
            }

            <form method="post" action="/Identity/Account/Login">
                <input name="Input.Email" placeholder="Email" required />
                <input name="Input.Password" type="password" placeholder="Mật khẩu" required />
                <button type="submit">Đăng nhập</button>
            </form>
        </div>

        <!-- REGISTER -->
        <div class="form-container register-container">
            <h2><i class="fas fa-user-plus"></i> Đăng ký</h2>

            @if (tab == "register" && error != null)
            {
                <div class="error">@error</div>
            }

            <form method="post" action="/Identity/Account/Register">
                <input name="Input.FullName" placeholder="Họ và tên" required />
                <input name="Input.Email" placeholder="Email" required />
                <input name="Input.Password" type="password" placeholder="Mật khẩu" required />
                <input name="Input.ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" required />
                <button type="submit">Đăng ký</button>
            </form>
        </div>

        <!-- OVERLAY -->
        <div class="overlay">
            <div>
                @if (tab == "register")
                {
                    <h2>Chào mừng quay lại!</h2>
                    <p>Nếu bạn đã có tài khoản, hãy đăng nhập để tiếp tục</p>
                    <button class="ghost-btn" onclick="switchToLogin()">Đăng nhập</button>
                }
                else
                {
                    <h2>Xin chào!</h2>
                    <p>Chưa có tài khoản? Đăng ký ngay để bắt đầu</p>
                    <button class="ghost-btn" onclick="switchToRegister()">Đăng ký</button>
                }
            </div>
        </div>

    </div>

    <script>
        const container = document.getElementById("container");

        function switchToRegister() {
            container.classList.add("active");
        }

        function switchToLogin() {
            container.classList.remove("active");
        }
    </script>

</body>
</html>
