@model IEnumerable<GearsHouse.Models.Product>
@inject GearsHouse.Repositories.ICategoryRepository _categoryRepository
@inject GearsHouse.Repositories.IBrandRepository _brandRepository
@{
    ViewData["Title"] = "Products";
    // Remove Layout = null; to use default _Layout
    var categories = await _categoryRepository.GetAllAsync();
    var brands = await _brandRepository.GetAllAsync();
}

@section Styles {
    <!-- Extend Tailwind Config for this page -->
    <script>
        // Check if tailwind config exists, if not create it (fallback), otherwise extend it
        if (typeof tailwind === 'undefined') {
             // If for some reason tailwind isn't loaded yet (unlikely with _Layout), we might need to wait or define it.
             // But usually it is defined in _Layout.
        }
        
        // We use the existing tailwind object from _Layout and extend/override it.
        // Note: tailwind.config is usually processed when the script tag with the config is parsed.
        // Since _Layout has already run, we might need to rely on the fact that we can modify the config before the body renders?
        // Actually, the CDN observes the DOM. Let's try to merge our settings.
        
        tailwind.config.theme.extend = {
            ...tailwind.config.theme.extend,
            colors: {
                ...tailwind.config.theme.extend.colors,
                // Overriding/Adding colors specific to Product Page
                "primary": "#8b5cf6", // Purple override
                "primary-hover": "#a78bfa",
                "secondary": "#06b6d4",
                "accent": "#ef4444",
                "background-light": "#f5f7f8",
                "background-dark": "#0f1115",
                "surface-dark": "#181b21",
                "surface-hover": "#22262e",
                "border-dark": "#2d3340",
                "text-secondary": "#9ca3af"
            },
            fontFamily: {
                ...tailwind.config.theme.extend.fontFamily,
                "display": ["Space Grotesk", "sans-serif"],
                "body": ["Noto Sans", "sans-serif"],
            },
            borderRadius: {
                ...tailwind.config.theme.extend.borderRadius,
                "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px"
            },
            backgroundImage: {
                 ...tailwind.config.theme.extend.backgroundImage,
                  'neon-gradient': 'linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%)',
                  'card-gradient': 'linear-gradient(to bottom, rgba(255,255,255,0.02), transparent)',
                  'glow-radial': 'radial-gradient(circle at center, rgba(139, 92, 246, 0.15) 0%, transparent 70%)',
            },
            animation: {
                'pulse-slow': 'pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                'float': 'float 6s ease-in-out infinite',
            },
            keyframes: {
                float: {
                    '0%, 100%': { transform: 'translateY(0)' },
                    '50%': { transform: 'translateY(-20px)' },
                }
            }
        }
    </script>
    <style>
        /* Page specific overrides */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0f1115; }
        ::-webkit-scrollbar-thumb { background: #2d3340; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #8b5cf6; }
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; }
        .neon-text-shadow { text-shadow: 0 0 15px rgba(139, 92, 246, 0.5); }
        .neon-box-shadow { box-shadow: 0 0 15px rgba(139, 92, 246, 0.2); }
        .text-glow-primary { text-shadow: 0 0 10px rgba(139, 92, 246, 0.6); }
        .text-glow-secondary { text-shadow: 0 0 10px rgba(6, 182, 212, 0.6); }
        .text-glow-accent { text-shadow: 0 0 10px rgba(239, 68, 68, 0.6); }
    </style>
}

<!-- Ambient Background Effects -->
<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Cyber Grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8b5cf6_1px,transparent_1px),linear-gradient(to_bottom,#8b5cf6_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-[0.07]"></div>
    
    <!-- Glow Orbs -->
    <div class="absolute top-0 left-0 w-full h-full">
        <div class="absolute -top-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-primary/20 blur-[120px] mix-blend-screen animate-pulse-slow"></div>
        <div class="absolute top-[20%] -right-[10%] w-[40%] h-[40%] rounded-full bg-secondary/10 blur-[100px] mix-blend-screen animate-pulse-slow" style="animation-delay: 2s;"></div>
        <div class="absolute -bottom-[20%] left-[20%] w-[40%] h-[40%] rounded-full bg-accent/10 blur-[100px] mix-blend-screen animate-pulse-slow" style="animation-delay: 4s;"></div>
    </div>
    
    <!-- Floating Particles (Simulated with simple divs) -->
    <div class="absolute top-[15%] left-[15%] w-2 h-2 rounded-full bg-primary/40 blur-[1px] animate-float"></div>
    <div class="absolute top-[45%] right-[25%] w-3 h-3 rounded-full bg-secondary/40 blur-[1px] animate-float" style="animation-delay: 1.5s;"></div>
    <div class="absolute bottom-[25%] left-[35%] w-1.5 h-1.5 rounded-full bg-accent/40 blur-[1px] animate-float" style="animation-delay: 3s;"></div>
</div>

<div class="layout-container relative z-10 flex h-full grow flex-col max-w-[1500px] mx-auto w-full px-4 md:px-6 lg:px-8 py-10">
    <div class="flex flex-wrap gap-2 px-2 py-2 mb-6">
        <a class="text-text-secondary text-xs uppercase tracking-wider font-bold hover:text-primary transition-colors" href="/">Home</a>
        <span class="text-text-secondary text-xs font-bold">/</span>
        <span class="text-primary text-xs uppercase tracking-wider font-bold drop-shadow-[0_0_8px_rgba(139,92,246,0.6)]">Products</span>
    </div>
    <div class="flex flex-col lg:flex-row gap-12">
        <aside class="w-full lg:w-72 flex-shrink-0 flex flex-col gap-8">
            <div class="flex items-center justify-between pb-2 border-b border-border-dark/40">
                <h3 class="text-white text-lg font-display font-bold uppercase tracking-wide">Filters</h3>
                <button onclick="clearFilters()" class="text-accent text-xs font-bold uppercase tracking-wider hover:text-accent/80 hover:drop-shadow-[0_0_5px_rgba(239,68,68,0.8)] transition-all">Clear All</button>
            </div>
            <div class="flex flex-col rounded-2xl border border-border-dark bg-surface-dark overflow-hidden group shadow-md transition-shadow hover:shadow-[0_0_20px_rgba(139,92,246,0.15)]">
                <div class="flex items-center justify-between gap-6 px-6 py-4 bg-surface-dark border-b border-border-dark/50">
                    <p class="text-white text-sm font-display font-bold uppercase tracking-wide flex items-center gap-3">
                        <span class="w-1.5 h-1.5 bg-primary rounded-full shadow-[0_0_8px_rgba(139,92,246,0.8)]"></span>
                        Khoảng Giá
                    </p>
                </div>
                <div class="px-6 py-5 flex flex-col gap-4">
                    <!-- Presets -->
                    <div class="flex flex-col gap-2.5">
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="all" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" checked onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">Tất cả</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="0-1000000" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">Dưới 1 triệu</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="1000000-5000000" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">1 - 5 triệu</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="5000000-15000000" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">5 - 15 triệu</span>
                        </label>
                         <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="15000000-30000000" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">15 - 30 triệu</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="pricePreset" value="30000000-max" class="peer size-4 border-border-dark bg-[#0f1115] checked:bg-primary checked:border-primary focus:ring-0 cursor-pointer transition-all" onchange="handlePricePreset(this)">
                            <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors">Trên 30 triệu</span>
                        </label>
                    </div>

                    <!-- Custom Input -->
                    <div class="pt-4 mt-2 border-t border-border-dark/40">
                        <p class="text-[11px] text-text-secondary mb-3 uppercase font-bold tracking-wider opacity-80">Tự nhập khoảng giá (VNĐ)</p>
                        <div class="flex items-center gap-2 mb-3">
                            <div class="relative w-full">
                                <input id="minPrice" type="number" placeholder="Từ" class="w-full bg-surface-hover border border-border-dark rounded-lg px-3 py-2 text-sm text-white focus:border-primary focus:ring-1 focus:ring-primary/50 placeholder-gray-600 transition-all" oninput="handleCustomPriceInput()">
                            </div>
                            <span class="text-text-secondary font-medium">-</span>
                            <div class="relative w-full">
                                <input id="maxPrice" type="number" placeholder="Đến" class="w-full bg-surface-hover border border-border-dark rounded-lg px-3 py-2 text-sm text-white focus:border-primary focus:ring-1 focus:ring-primary/50 placeholder-gray-600 transition-all" oninput="handleCustomPriceInput()">
                            </div>
                        </div>
                        <button onclick="applyCustomPrice()" class="w-full py-2.5 bg-primary/10 hover:bg-primary hover:text-white text-primary border border-primary/30 hover:border-primary rounded-lg text-xs font-bold uppercase tracking-wider transition-all duration-300 flex items-center justify-center gap-2 group/btn">
                            <span>Áp dụng</span>
                            <span class="material-symbols-outlined text-[16px] group-hover/btn:translate-x-1 transition-transform">arrow_forward</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-5">
                <details class="flex flex-col rounded-2xl border border-border-dark bg-surface-dark overflow-hidden group shadow-md" open="">
                    <summary class="flex cursor-pointer items-center justify-between gap-6 px-6 py-4 bg-surface-dark hover:bg-surface-hover transition-colors select-none">
                        <p class="text-white text-sm font-display font-bold uppercase tracking-wide flex items-center gap-3">
                            <span class="w-1.5 h-1.5 bg-secondary rounded-full shadow-[0_0_8px_rgba(6,182,212,0.8)]"></span>
                            Danh Mục (Categories)
                        </p>
                        <span class="material-symbols-outlined text-text-secondary group-open:rotate-180 transition-transform text-sm">expand_more</span>
                    </summary>
                    <div class="px-6 pb-6 pt-2 flex flex-col gap-3.5 border-t border-border-dark/50">
                        @foreach (var category in categories)
                        {
                            <label class="flex items-center gap-3 cursor-pointer group/item">
                                <div class="relative flex items-center">
                                    <input class="peer size-4 appearance-none rounded border border-border-dark bg-[#0f1115] checked:bg-secondary checked:border-secondary transition-all cursor-pointer shadow-sm category-checkbox" type="checkbox" value="@category.Id" onchange="handleCategoryChange(this)" />
                                    <span class="material-symbols-outlined absolute text-black opacity-0 peer-checked:opacity-100 text-[14px] left-[1px] top-[1px] pointer-events-none font-bold">check</span>
                                </div>
                                <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors group-hover/item:pl-1 duration-200">@category.Name</span>
                            </label>
                        }
                    </div>
                </details>
                <details class="flex flex-col rounded-2xl border border-border-dark bg-surface-dark overflow-hidden group shadow-md">
                    <summary class="flex cursor-pointer items-center justify-between gap-6 px-6 py-4 bg-surface-dark hover:bg-surface-hover transition-colors select-none">
                        <p class="text-white text-sm font-display font-bold uppercase tracking-wide flex items-center gap-3">
                            <span class="w-1.5 h-1.5 bg-accent rounded-full shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                            Thương Hiệu (Brands)
                        </p>
                        <span class="material-symbols-outlined text-text-secondary group-open:rotate-180 transition-transform text-sm">expand_more</span>
                    </summary>
                    <div class="px-6 pb-6 pt-2 flex flex-col gap-3.5 border-t border-border-dark/50">
                        @foreach (var brand in brands)
                        {
                            <label class="flex items-center gap-3 cursor-pointer group/item">
                                <span class="relative flex items-center">
                                    <input class="peer size-4 appearance-none rounded border border-border-dark bg-[#0f1115] checked:bg-accent checked:border-accent transition-all cursor-pointer brand-checkbox" type="checkbox" value="@brand.BrandId" onchange="handleBrandChange(this)" />
                                    <span class="material-symbols-outlined absolute text-black opacity-0 peer-checked:opacity-100 text-[14px] left-[1px] top-[1px] pointer-events-none font-bold">check</span>
                                </span>
                                <span class="text-text-secondary text-sm group-hover/item:text-white transition-colors group-hover/item:pl-1 duration-200">@brand.Name</span>
                            </label>
                        }
                    </div>
                </details>
            </div>
        </aside>
        <main class="flex-1 flex flex-col gap-8">
            <div class="flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-border-dark bg-surface-dark px-6 py-5 shadow-lg relative overflow-hidden backdrop-blur-sm">
                <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-gradient-to-b from-primary to-transparent shadow-[0_0_10px_rgba(139,92,246,0.3)]"></div>
                <p class="text-text-secondary text-sm font-medium showing-products-text">Showing @Model.Count() products</p>
                <div class="flex items-center gap-6">
                    <div class="flex items-center gap-3">
                        <label class="text-text-secondary text-xs font-bold uppercase tracking-wider hidden sm:block" for="sort">Sort By:</label>
                        <div class="relative group">
                            <select class="appearance-none bg-[#0f1115] text-white text-sm font-medium rounded-lg border border-border-dark py-2.5 pl-4 pr-10 focus:border-primary focus:ring-0 cursor-pointer shadow-sm hover:border-primary/50 hover:shadow-[0_0_10px_rgba(139,92,246,0.15)] transition-all duration-300" id="sort" onchange="filterProducts()">
                                <option value="">Most Relevant</option>
                                <option value="price_asc">Price: Low to High</option>
                                <option value="price_desc">Price: High to Low</option>
                                <option value="newest">Newest Arrivals</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-primary pointer-events-none text-sm group-hover:drop-shadow-[0_0_5px_rgba(139,92,246,0.8)] transition-all">expand_more</span>
                        </div>
                    </div>
                    <div class="h-6 w-px bg-border-dark hidden sm:block"></div>
                    <div class="flex gap-1 bg-[#0f1115] p-1.5 rounded-lg border border-border-dark">
                        <button class="p-1.5 rounded bg-surface-dark text-primary shadow-[0_0_8px_rgba(139,92,246,0.3)] border border-border-dark">
                            <span class="material-symbols-outlined text-[20px]">grid_view</span>

                            </button>
                            <button class="p-1.5 rounded text-text-secondary hover:text-white transition-colors">
                                <span class="material-symbols-outlined text-[20px]">view_list</span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Product List Container -->
                <div id="product-list-container">
                    <partial name="_ProductList" model="Model" />
                </div>

                <!-- Pagination (Placeholder) -->
                <div class="flex justify-center items-center gap-3 mt-12 py-4">
                     <!-- Implementation dependent on backend pagination support -->
                </div>
            </main>
        </div>
    </div>


@section Scripts {
    <script>
        let debounceTimer;

        function updatePriceLabel(value) {
            document.getElementById('priceLabel').innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
        }

        function debounceFilter() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(filterProducts, 500);
        }

        function handleCategoryChange(checkbox) {
            if(checkbox.checked) {
                document.querySelectorAll('.category-checkbox').forEach(cb => {
                    if(cb !== checkbox) cb.checked = false;
                });
            }
            filterProducts();
        }
        
        function handleBrandChange(checkbox) {
            if(checkbox.checked) {
                document.querySelectorAll('.brand-checkbox').forEach(cb => {
                    if(cb !== checkbox) cb.checked = false;
                });
            }
            filterProducts();
        }

        function handlePricePreset(radio) {
            if (!radio.checked) return;
            
            const val = radio.value;
            const minInput = document.getElementById('minPrice');
            const maxInput = document.getElementById('maxPrice');
            
            if (val === 'all') {
                minInput.value = '';
                maxInput.value = '';
            } else {
                const parts = val.split('-');
                minInput.value = parts[0];
                maxInput.value = parts[1] === 'max' ? '' : parts[1];
            }
            
            filterProducts();
        }

        function handleCustomPriceInput() {
            // Uncheck presets if user types manually
            const radios = document.getElementsByName('pricePreset');
            radios.forEach(r => r.checked = false);
        }

        function applyCustomPrice() {
            filterProducts();
        }

        function clearFilters() {
            var searchInput = document.getElementById('navbarSearch');
            if(searchInput) searchInput.value = '';
            
            document.getElementById('minPrice').value = '';
            document.getElementById('maxPrice').value = '';
            
            // Reset presets
            document.querySelectorAll('input[name="pricePreset"]').forEach(r => {
                if(r.value === 'all') r.checked = true;
                else r.checked = false;
            });

            document.querySelectorAll('input[type=checkbox]').forEach(cb => cb.checked = false);
            document.getElementById('sort').selectedIndex = 0;
            
            filterProducts();
        }

        function filterProducts() {
            var searchInput = document.getElementById('navbarSearch');
            var keyword = searchInput ? searchInput.value : '';
            
            var minPrice = document.getElementById('minPrice').value;
            var maxPrice = document.getElementById('maxPrice').value;
            var sort = document.getElementById('sort').value;
            
            var categoryId = 0;
            var catCb = document.querySelector('.category-checkbox:checked');
            if(catCb) categoryId = catCb.value;

            var brandId = 0;
            var brandCb = document.querySelector('.brand-checkbox:checked');
            if(brandCb) brandId = brandCb.value;
            
            var url = `/Product/Filter?keyword=${encodeURIComponent(keyword)}&categoryId=${categoryId}&brandId=${brandId}&minPrice=${minPrice}&maxPrice=${maxPrice}&sort=${sort}`;
            
            // Show loading state
            var container = document.getElementById('product-list-container');
            container.style.opacity = '0.5';

            fetch(url)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.text();
                })
                .then(html => {
                    container.innerHTML = html;
                    container.style.opacity = '1';
                    
                    // Update result count
                    var countInput = document.getElementById('result-count');
                    if(countInput) {
                        document.querySelector('.showing-products-text').innerText = 'Showing ' + countInput.value + ' products';
                    }
                })
                .catch(error => {
                    console.error('Error filtering products:', error);
                    container.style.opacity = '1';
                });
        }
    </script>
}
