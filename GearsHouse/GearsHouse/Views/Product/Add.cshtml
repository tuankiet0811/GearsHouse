@model GearsHouse.Models.Product
@{
    var xRequestedWith = ViewContext?.HttpContext?.Request?.Headers["X-Requested-With"].ToString();
    if (string.Equals(xRequestedWith, "XMLHttpRequest", StringComparison.OrdinalIgnoreCase))
    {
        Layout = null;
    }
}

<div class="w-full max-w-6xl mx-auto relative p-2">
    <!-- Tech Background Elements -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none rounded-3xl"></div>
    <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Header -->
    <div class="flex items-center justify-between mb-8 pb-6 border-b border-cyan-500/20 relative z-10">
        <div class="absolute bottom-0 left-0 h-[2px] w-32 bg-gradient-to-r from-cyan-400 to-blue-500 shadow-[0_0_10px_#06b6d4]"></div>
        <h2 class="text-3xl font-black text-white flex items-center gap-4 tracking-tight">
            <div class="relative group">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl blur opacity-30 group-hover:opacity-100 transition duration-500"></div>
                <div class="relative p-3 rounded-xl bg-[#0b1015] border border-cyan-500/30 shadow-[inset_0_0_20px_rgba(6,182,212,0.1)]">
                    <span class="material-symbols-outlined text-cyan-400 text-3xl">add_box</span>
                </div>
            </div>
            <div class="flex flex-col">
                <span class="text-xs font-bold text-cyan-500 tracking-widest uppercase mb-1">Quản lý sản phẩm</span>
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-cyan-100 to-cyan-400 filter drop-shadow-[0_0_10px_rgba(6,182,212,0.3)]">Thêm Sản Phẩm Mới</span>
            </div>
        </h2>
        <button type="button" onclick="closeProductModal()" class="group relative px-4 py-2 rounded-lg bg-[#0b1015] border border-white/10 text-gray-400 hover:text-white hover:border-cyan-500/50 transition-all duration-300 overflow-hidden">
            <div class="absolute inset-0 bg-cyan-500/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
            <div class="relative flex items-center gap-2">
                <span class="text-xs font-bold uppercase tracking-wider">Đóng</span>
                <span class="material-symbols-outlined text-lg group-hover:rotate-90 transition-transform duration-300">close</span>
            </div>
        </button>
    </div>

    <!-- Form -->
    <form asp-action="Add" method="post" enctype="multipart/form-data" id="form-add-product" onsubmit="submitAddProductForm(event)" class="space-y-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Main Info -->
            <div class="lg:col-span-8 space-y-6">
                <!-- Basic Info Card -->
                <div class="relative group rounded-2xl bg-[#0b1015]/80 backdrop-blur-md border border-white/5 p-1">
                    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/20 via-transparent to-blue-500/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="relative rounded-xl bg-[#0b1015] p-6 h-full">
                        <h3 class="text-sm font-bold text-cyan-400 uppercase tracking-wider mb-6 flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">dns</span>
                            Thông Tin Cơ Bản
                        </h3>
                        
                        <div class="space-y-6">
                            <!-- Name -->
                            <div class="space-y-2">
                                <label asp-for="Name" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Tên Sản Phẩm</label>
                                <div class="relative group/input">
                                    <input asp-for="Name" class="w-full bg-[#151a21] border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-600 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all outline-none font-medium shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)] group-hover/input:border-white/20" placeholder="Nhập tên sản phẩm..." autocomplete="off" />
                                    <div class="absolute right-3 top-1/2 -translate-y-1/2 p-1 rounded bg-white/5 border border-white/5">
                                        <span class="material-symbols-outlined text-gray-500 text-lg">edit</span>
                                    </div>
                                </div>
                                <span asp-validation-for="Name" class="text-xs text-red-500 font-bold ml-1"></span>
                            </div>

                            <!-- Price & Quantity -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label asp-for="Price" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Giá Bán (VNĐ)</label>
                                    <div class="relative group/input">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-cyan-500 font-mono font-bold">₫</span>
                                        <input asp-for="Price" type="number" class="w-full bg-[#151a21] border border-white/10 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-600 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all outline-none font-mono text-lg shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]" placeholder="0" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-xs text-red-500 font-bold ml-1"></span>
                                </div>
                                <div class="space-y-2">
                                    <label asp-for="Quantity" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Tồn Kho</label>
                                    <div class="relative group/input">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-cyan-500 font-mono font-bold">#</span>
                                        <input asp-for="Quantity" type="number" class="w-full bg-[#151a21] border border-white/10 rounded-lg pl-10 pr-4 py-3 text-white placeholder-gray-600 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all outline-none font-mono text-lg shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]" placeholder="0" />
                                    </div>
                                    <span asp-validation-for="Quantity" class="text-xs text-red-500 font-bold ml-1"></span>
                                </div>
                            </div>

                            <!-- Category & Brand -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label asp-for="CategoryId" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Danh Mục</label>
                                    <div class="relative">
                                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="w-full bg-[#151a21] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all outline-none appearance-none cursor-pointer shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]">
                                            <option value="">-- Chọn danh mục --</option>
                                        </select>
                                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-cyan-500 pointer-events-none material-symbols-outlined">category</span>
                                    </div>
                                    <span asp-validation-for="CategoryId" class="text-xs text-red-500 font-bold ml-1"></span>
                                </div>
                                <div class="space-y-2">
                                    <label asp-for="BrandId" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Thương Hiệu</label>
                                    <div class="relative">
                                        <select asp-for="BrandId" asp-items="ViewBag.Brands" class="w-full bg-[#151a21] border border-white/10 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all outline-none appearance-none cursor-pointer shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]">
                                            <option value="">-- Chọn thương hiệu --</option>
                                        </select>
                                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-cyan-500 pointer-events-none material-symbols-outlined">branding_watermark</span>
                                    </div>
                                    <span asp-validation-for="BrandId" class="text-xs text-red-500 font-bold ml-1"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Detailed Info Card (TinyMCE) -->
                <div class="relative group rounded-2xl bg-[#0b1015]/80 backdrop-blur-md border border-white/5 p-1">
                     <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 via-transparent to-cyan-500/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="relative rounded-xl bg-[#0b1015] p-6">
                         <h3 class="text-sm font-bold text-blue-400 uppercase tracking-wider mb-6 flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">description</span>
                            Chi Tiết & Thông Số
                        </h3>
                        <div class="space-y-6">
                            <div class="space-y-2">
                                <label asp-for="ProductInfo" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Mô Tả Sản Phẩm</label>
                                <div class="border border-white/10 rounded-lg overflow-hidden focus-within:border-cyan-500 transition-colors">
                                    <textarea asp-for="ProductInfo" id="ProductInfoAdd" class="tinymce-editor w-full bg-[#151a21] text-white min-h-[300px]"></textarea>
                                </div>
                                <span asp-validation-for="ProductInfo" class="text-xs text-red-500 font-bold ml-1"></span>
                            </div>

                            <div class="space-y-2">
                                <label asp-for="TechnicalSpecs" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1">Thông Số Kỹ Thuật</label>
                                <div class="border border-white/10 rounded-lg overflow-hidden focus-within:border-cyan-500 transition-colors">
                                    <textarea asp-for="TechnicalSpecs" id="TechnicalSpecsAdd" class="tinymce-editor w-full bg-[#151a21] text-white min-h-[200px]"></textarea>
                                </div>
                                <span asp-validation-for="TechnicalSpecs" class="text-xs text-red-500 font-bold ml-1"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Images -->
            <div class="lg:col-span-4 space-y-6">
                 <div class="relative group rounded-2xl bg-[#0b1015]/80 backdrop-blur-md border border-white/5 p-1 h-full">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 via-transparent to-blue-500/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="relative rounded-xl bg-[#0b1015] p-6 h-full flex flex-col">
                        <h3 class="text-sm font-bold text-purple-400 uppercase tracking-wider mb-6 flex items-center gap-2">
                            <span class="material-symbols-outlined text-lg">imagesmode</span>
                            Hình Ảnh
                        </h3>

                        <div class="space-y-6 flex-1">
                            <!-- Main Image -->
                            <div class="space-y-3">
                                <label asp-for="ImageUrl" class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1 block">Ảnh Đại Diện</label>
                                <div class="relative group w-full aspect-square border-2 border-dashed border-white/10 rounded-xl hover:border-cyan-500/50 hover:bg-cyan-500/5 transition-all duration-300 flex flex-col items-center justify-center overflow-hidden cursor-pointer bg-[#151a21]" onclick="document.getElementById('imageInput').click()">
                                    <input type="file" asp-for="ImageUrl" id="imageInput" class="hidden" accept="image/*" onchange="previewImage(this)" />
                                    <div id="imagePlaceholder" class="flex flex-col items-center gap-4 text-gray-500 group-hover:text-cyan-400 transition-colors p-4 text-center">
                                        <div class="p-4 rounded-full bg-white/5 group-hover:bg-cyan-500/10 transition-colors shadow-inner">
                                            <span class="material-symbols-outlined text-4xl">cloud_upload</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-bold block mb-1">Tải ảnh lên</span>
                                            <span class="text-[10px] text-gray-600 uppercase tracking-wide">PNG, JPG tối đa 5MB</span>
                                        </div>
                                    </div>
                                    <img id="imagePreview" src="#" class="absolute inset-0 w-full h-full object-contain hidden bg-[#0b1015] p-2" />
                                    <!-- Overlay -->
                                    <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center pointer-events-none backdrop-blur-[2px]" id="changeOverlay">
                                        <span class="material-symbols-outlined text-cyan-400 text-3xl mb-2">edit</span>
                                        <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">Thay đổi ảnh</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Gallery Images -->
                            <div class="space-y-3">
                                <label class="text-xs font-bold text-gray-400 uppercase tracking-wide ml-1 block">Thư Viện Ảnh</label>
                                <div class="relative w-full border border-white/10 rounded-xl p-4 bg-[#151a21] hover:border-cyan-500/30 transition-colors">
                                    <input type="file" name="galleryImages" id="galleryInput" class="w-full text-xs text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-cyan-500/10 file:text-cyan-400 hover:file:bg-cyan-500/20 transition-all cursor-pointer" accept="image/*" multiple onchange="handleGalleryChange(this)" />
                                    <div id="galleryPreview" class="grid grid-cols-3 gap-2 mt-4"></div>
                                </div>
                                <p class="text-[10px] text-gray-500 italic ml-1">* Chọn nhiều ảnh để tạo thư viện ảnh cho sản phẩm</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-end gap-4 pt-6 border-t border-cyan-500/20">
            <button type="button" onclick="closeProductModal()" class="px-6 py-3 rounded-lg border border-white/10 text-gray-400 font-bold hover:bg-white/5 hover:text-white transition-all text-xs uppercase tracking-wider">
                Hủy Bỏ
            </button>
            <button type="submit" class="relative group px-8 py-3 rounded-lg bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold shadow-[0_0_20px_rgba(6,182,212,0.3)] hover:shadow-[0_0_30px_rgba(6,182,212,0.5)] transition-all flex items-center gap-3 overflow-hidden">
                <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                <span class="material-symbols-outlined text-xl group-hover:animate-bounce relative z-10">save</span>
                <span class="text-xs uppercase tracking-widest relative z-10">Lưu Sản Phẩm</span>
            </button>
        </div>
    </form>
</div>

<!-- TinyMCE & Scripts -->
<script>
    (function () {
        var cdns = [
            'https://cdn.tiny.cloud/1/mceyvkr5qw1v3d6pw7hqems6xoqgcxo582jxoxtkqhpm9cp3/tinymce/7/tinymce.min.js',
            'https://cdn.jsdelivr.net/npm/tinymce@7/tinymce.min.js'
        ];
        function initTinyMCE() {
            if (!window.tinymce) return;
            
            // Cleanup existing instances
            try { 
                if (tinymce.get('ProductInfoAdd')) tinymce.get('ProductInfoAdd').remove();
                if (tinymce.get('TechnicalSpecsAdd')) tinymce.get('TechnicalSpecsAdd').remove();
            } catch (e) { console.warn(e); }

            const commonConfig = {
                plugins: 'preview importcss searchreplace autolink autosave save directionality code visualblocks visualchars fullscreen image link media template codesample table charmap pagebreak nonbreaking anchor insertdatetime advlist lists wordcount help charmap quickbars emoticons',
                menubar: 'file edit view insert format tools table help',
                toolbar: 'undo redo | bold italic underline strikethrough | fontfamily fontsize blocks | alignleft aligncenter alignright alignjustify | outdent indent |  numlist bullist | forecolor backcolor removeformat | pagebreak | charmap emoticons | fullscreen  preview save print | insertfile image media template link anchor codesample | ltr rtl',
                toolbar_sticky: true,
                skin: 'oxide-dark',
                content_css: 'dark',
                height: 300,
                setup: function (editor) {
                    editor.on('change', function () {
                        editor.save();
                    });
                }
            };

            tinymce.init({
                selector: '#ProductInfoAdd',
                ...commonConfig,
                placeholder: 'Nhập mô tả sản phẩm...'
            });

            tinymce.init({
                selector: '#TechnicalSpecsAdd',
                ...commonConfig,
                placeholder: 'Nhập thông số kỹ thuật...'
            });
        }

        function loadScript(idx) {
            if (window.tinymce) { initTinyMCE(); return; }
            if (idx >= cdns.length) return;
            
            var s = document.createElement('script');
            s.src = cdns[idx];
            s.referrerPolicy = 'origin';
            s.defer = true;
            s.onload = initTinyMCE;
            s.onerror = function () { loadScript(idx + 1); };
            document.head.appendChild(s);
        }

        // Run immediately
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function () { loadScript(0); });
        } else { loadScript(0); }
    })();

    // GSAP Animation
    if (typeof gsap !== 'undefined') {
        gsap.from("#form-add-product > div", {
            y: 20,
            opacity: 0,
            duration: 0.5,
            stagger: 0.1,
            ease: "power3.out",
            clearProps: "all"
        });
    }

    // Image Preview
    function previewImage(input) {
        const placeholder = document.getElementById('imagePlaceholder');
        const preview = document.getElementById('imagePreview');
        const overlay = document.getElementById('changeOverlay');
        
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                placeholder.classList.add('hidden');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Gallery Logic
    function handleGalleryChange(input) {
        if (!input.customDataTransfer) {
            input.customDataTransfer = new DataTransfer();
        }
        const dt = input.customDataTransfer;
        
        // Add new files
        if (input.files) {
            Array.from(input.files).forEach(file => {
                 // Check duplicate (simple check by name + size)
                 let exists = false;
                 for (let i = 0; i < dt.files.length; i++) {
                     if (dt.files[i].name === file.name && dt.files[i].size === file.size) {
                         exists = true;
                         break;
                     }
                 }
                 if (!exists) dt.items.add(file);
            });
        }
        
        // Update input.files
        input.files = dt.files;
        
        renderGalleryPreviews(input);
    }

    function renderGalleryPreviews(input) {
        const previewContainer = document.getElementById('galleryPreview');
        previewContainer.innerHTML = '';
        const dt = input.customDataTransfer;
        
        if (dt && dt.files) {
             Array.from(dt.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-lg overflow-hidden border border-white/10 group';
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <button type="button" onclick="removeGalleryImage(${index})" class="p-2 rounded-full bg-red-500/20 text-red-500 hover:bg-red-500 hover:text-white transition-colors">
                                <span class="material-symbols-outlined text-xl">delete</span>
                            </button>
                        </div>
                    `;
                    previewContainer.appendChild(div);
                }
                reader.readAsDataURL(file);
            });
        }
    }

    function removeGalleryImage(index) {
        const input = document.getElementById('galleryInput');
        if (!input || !input.customDataTransfer) return;
        
        const dt = input.customDataTransfer;
        const newDt = new DataTransfer();
        
        Array.from(dt.files).forEach((file, i) => {
            if (i !== index) newDt.items.add(file);
        });
        
        input.customDataTransfer = newDt;
        input.files = newDt.files;
        
        renderGalleryPreviews(input);
    }
</script>