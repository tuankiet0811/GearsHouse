@model IEnumerable<GearsHouse.Models.Product>
@{
    var discounts = ViewBag.ProductDiscounts as Dictionary<int, (decimal price, int percent)>;
    var reviewStats = ViewBag.ReviewStats as Dictionary<int, (double Average, int Count)>;
}

<input type="hidden" id="result-count" value="@Model.Count()" />

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
    @if (!Model.Any())
    {
        <div class="col-span-full flex flex-col items-center justify-center py-12 text-center">
            <span class="material-symbols-outlined text-6xl text-text-secondary mb-4">search_off</span>
            <h3 class="text-white text-xl font-display font-bold mb-2">No products found</h3>
            <p class="text-text-secondary">Try adjusting your filters or search criteria.</p>
        </div>
    }
    else
    {
        foreach (var product in Model)
        {
            <div class="group relative flex flex-col rounded-2xl bg-surface-dark border border-border-dark overflow-hidden transition-all duration-500 hover:border-primary/50 hover:shadow-[0_0_35px_rgba(139,92,246,0.15)] hover:-translate-y-2">
                <!-- Cyber Frame Effects -->
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-transparent via-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute top-0 right-0 w-1 h-full bg-gradient-to-b from-transparent via-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <div class="aspect-square relative p-8 bg-card-gradient flex items-center justify-center overflow-hidden">
                    <div class="absolute inset-0 bg-glow-radial blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-in-out"></div>
                    
                    <!-- Tech Ring Decoration -->
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-20 transition-opacity duration-700 pointer-events-none">
                        <svg class="w-[80%] h-[80%] animate-[spin_10s_linear_infinite]" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="48" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="10 5" class="text-primary"></circle>
                            <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="20 10" class="text-secondary" style="transform-origin: center; transform: rotate(45deg);"></circle>
                        </svg>
                    </div>

                    @if (discounts != null && discounts.ContainsKey(product.Id))
                    {
                        <div class="absolute top-4 left-4 z-20 bg-accent/10 border border-accent/30 text-accent backdrop-blur-md text-[10px] font-bold px-3 py-1.5 rounded-md uppercase tracking-wider shadow-[0_0_15px_rgba(239,68,68,0.3)] animate-pulse">
                            -@discounts[product.Id].percent%
                        </div>
                    }
                    else if (DateTime.Now < DateTime.Now.AddDays(7)) 
                    {
                         <div class="absolute top-4 left-4 z-20 bg-primary/10 border border-primary/30 text-primary backdrop-blur-md text-[10px] font-bold px-3 py-1.5 rounded-md uppercase tracking-wider shadow-[0_0_15px_rgba(139,92,246,0.3)] animate-pulse">New</div>
                    }

                    <img alt="@product.Name" class="w-full h-full object-contain drop-shadow-2xl transition-transform duration-500 group-hover:scale-110 group-hover:rotate-1 relative z-10" src="@product.ImageUrl" />
                    
                    <button class="absolute top-4 right-4 z-20 p-2.5 rounded-full bg-[#0f1115]/80 text-text-secondary border border-border-dark hover:text-white hover:border-primary hover:bg-primary/20 hover:shadow-[0_0_15px_rgba(139,92,246,0.5)] transition-all opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 duration-300 backdrop-blur-sm">
                        <span class="material-symbols-outlined text-[18px]">favorite</span>
                    </button>
                </div>
                
                <div class="p-5 flex flex-col gap-3 flex-1 border-t border-border-dark/50 relative bg-surface-dark/30 backdrop-blur-sm">
                    <p class="text-primary text-xs font-bold uppercase tracking-wider group-hover:text-primary-hover transition-colors">
                        @(product.Category?.Name ?? "Gear")
                    </p>
                    <h3 class="text-white font-display font-bold text-lg leading-snug group-hover:text-primary transition-colors line-clamp-2 min-h-[3.5rem]">
                        @product.Name
                    </h3>
                    
                    <div class="flex gap-1 text-yellow-500 mt-1 text-sm items-center">
                        @{
                            double avgRating = 0;
                            int reviewCount = 0;
                            if (reviewStats != null && reviewStats.ContainsKey(product.Id))
                            {
                                avgRating = reviewStats[product.Id].Average;
                                reviewCount = reviewStats[product.Id].Count;
                            }
                            int fullStars = (int)avgRating;
                            bool hasHalfStar = avgRating - fullStars >= 0.5;
                        }
                        <div class="flex drop-shadow-[0_0_3px_rgba(234,179,8,0.5)]">
                            @for (int i = 0; i < fullStars; i++) { <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1">star</span> }
                            @if (hasHalfStar) { <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1">star_half</span> }
                            @for (int i = 0; i < (5 - fullStars - (hasHalfStar ? 1 : 0)); i++) { <span class="material-symbols-outlined text-[16px]">star</span> }
                        </div>
                        <span class="text-text-secondary text-xs ml-2 font-medium">(@reviewCount)</span>
                    </div>
                    
                    <div class="mt-auto pt-4 flex items-center justify-between">
                        <div class="flex flex-col">
                            @if (discounts != null && discounts.ContainsKey(product.Id))
                            {
                                <span class="text-text-secondary text-xs line-through whitespace-nowrap">@product.Price.ToString("N0") đ</span>
                                <span class="text-xl font-display font-bold text-white group-hover:text-glow-primary transition-all duration-300 whitespace-nowrap">@discounts[product.Id].price.ToString("N0") đ</span>
                            }
                            else
                            {
                                <span class="text-xl font-display font-bold text-white group-hover:text-glow-primary transition-all duration-300 whitespace-nowrap">@product.Price.ToString("N0") đ</span>
                            }
                        </div>
                        <a href="/Product/Display/@product.Id" class="size-11 rounded-xl bg-gradient-to-br from-primary to-purple-700 text-white flex items-center justify-center shadow-[0_0_15px_rgba(139,92,246,0.3)] hover:shadow-[0_0_25px_rgba(139,92,246,0.6)] hover:scale-105 active:scale-95 transition-all duration-300 group-hover:from-primary-hover group-hover:to-purple-600">
                            <span class="material-symbols-outlined">add_shopping_cart</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>
