@model IEnumerable<GearsHouse.Models.Promotion>

@{
    var activeCount = Model.Count(p => p.IsActive);
    var scheduledCount = Model.Count(p => p.StartDate > DateTime.Now);
    var expiredCount = Model.Count(p => p.EndDate < DateTime.Now);
}

<style>
    .glass-effect {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .hover-glow:hover {
        box-shadow: 0 0 20px rgba(13, 127, 242, 0.3);
    }
</style>

<!-- Page Heading -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 gsap-fade-up">
    <div class="flex flex-col gap-2">
        <h1 class="text-white text-4xl md:text-5xl font-bold leading-tight tracking-tight">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">Quản Lý Khuyến Mãi</span>
        </h1>
        <p class="text-[#9cabba] text-base md:text-lg font-normal leading-normal max-w-2xl">Tạo, theo dõi và quản lý các giảm giá thiết bị chơi game và các chiến dịch theo mùa.</p>
    </div>
    <!-- Quick Add Button (Desktop) -->
    <button onclick="openCreateModal()" class="hidden md:flex items-center gap-2 bg-gradient-to-r from-primary to-purple-600 hover:from-primary/90 hover:to-purple-600/90 text-white px-6 py-3 rounded-lg font-bold transition-all duration-300 transform hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(139,92,246,0.5)] group">
        <div class="bg-white/20 rounded-full p-1 group-hover:rotate-90 transition-transform duration-300">
            <span class="material-symbols-outlined text-sm">add</span>
        </div>
        <span>Chiến Dịch Mới</span>
    </button>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
    <!-- Active Deals -->
    <div class="glass-effect p-6 rounded-2xl border-l-4 border-l-accent-green relative overflow-hidden group hover:bg-[#1a2027] transition-all duration-300 hover:scale-[1.02] gsap-fade-up">
        <div class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 transform group-hover:scale-110 group-hover:rotate-12">
            <span class="material-symbols-outlined text-7xl text-accent-green">local_offer</span>
        </div>
        <div class="relative z-10">
            <p class="text-[#9cabba] text-xs font-bold uppercase tracking-wider mb-2">Ưu Đãi Đang Chạy</p>
            <div class="flex items-baseline gap-3">
                <p class="text-white text-4xl font-black tracking-tight gsap-counter">@activeCount</p>
                <span class="flex items-center text-accent-green text-xs font-bold bg-accent-green/10 px-2 py-1 rounded-full border border-accent-green/20">
                    <span class="material-symbols-outlined text-[12px] mr-1 animate-pulse">trending_up</span> Hoạt động
                </span>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-accent-green to-transparent opacity-50"></div>
    </div>
    
    <!-- Scheduled -->
    <div class="glass-effect p-6 rounded-2xl border-l-4 border-l-primary relative overflow-hidden group hover:bg-[#1a2027] transition-all duration-300 hover:scale-[1.02] gsap-fade-up">
        <div class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 transform group-hover:scale-110 group-hover:-rotate-12">
            <span class="material-symbols-outlined text-7xl text-primary">calendar_clock</span>
        </div>
        <div class="relative z-10">
            <p class="text-[#9cabba] text-xs font-bold uppercase tracking-wider mb-2">Đã Lên Lịch</p>
            <p class="text-white text-4xl font-black tracking-tight gsap-counter">@scheduledCount</p>
        </div>
         <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-transparent opacity-50"></div>
    </div>
    
    <!-- Expired -->
    <div class="glass-effect p-6 rounded-2xl border-l-4 border-l-gray-500 relative overflow-hidden group hover:bg-[#1a2027] transition-all duration-300 hover:scale-[1.02] gsap-fade-up">
        <div class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 transform group-hover:scale-110">
            <span class="material-symbols-outlined text-7xl text-gray-500">history</span>
        </div>
        <div class="relative z-10">
            <p class="text-[#9cabba] text-xs font-bold uppercase tracking-wider mb-2">Đã Hết Hạn</p>
            <p class="text-white text-4xl font-black tracking-tight gsap-counter">@expiredCount</p>
        </div>
         <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-gray-500 to-transparent opacity-50"></div>
    </div>
</div>

<!-- Controls & Table Section -->
<div class="flex flex-col gap-6 bg-[#1a2027]/50 rounded-2xl p-6 border border-[#283039] backdrop-blur-sm gsap-fade-up">
    <!-- Filter Bar -->
    <div class="flex flex-col lg:flex-row justify-between gap-4 items-start lg:items-center">
        <!-- Search -->
        <div class="relative w-full lg:w-96 group">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-gray-400 group-focus-within:text-primary transition-colors">search</span>
            </div>
            <input id="promotionSearch" onkeyup="searchPromotions()" class="w-full bg-[#111418] border border-[#3b4754] text-white text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/50 placeholder-gray-500 transition-all shadow-sm" placeholder="Tìm kiếm chiến dịch..." type="text" />
        </div>
        <!-- Status Filters -->
        <div class="flex flex-wrap gap-2">
            <label class="cursor-pointer group">
                <input checked="" class="peer sr-only" name="status" type="radio" onclick="filterStatus('all')" />
                <div class="px-4 py-2 rounded-lg bg-[#283039] text-[#9cabba] text-sm font-bold border border-transparent peer-checked:bg-primary/20 peer-checked:text-primary peer-checked:border-primary/50 peer-checked:shadow-[0_0_10px_rgba(13,127,242,0.3)] transition-all hover:bg-[#323b46]">Tất Cả</div>
            </label>
            <label class="cursor-pointer group">
                <input class="peer sr-only" name="status" type="radio" onclick="filterStatus('active')" />
                <div class="px-4 py-2 rounded-lg bg-[#283039] text-[#9cabba] text-sm font-bold border border-transparent peer-checked:bg-accent-green/20 peer-checked:text-accent-green peer-checked:border-accent-green/50 peer-checked:shadow-[0_0_10px_rgba(34,197,94,0.3)] transition-all hover:bg-[#323b46]">Đang Chạy</div>
            </label>
            <label class="cursor-pointer group">
                <input class="peer sr-only" name="status" type="radio" onclick="filterStatus('scheduled')" />
                <div class="px-4 py-2 rounded-lg bg-[#283039] text-[#9cabba] text-sm font-bold border border-transparent peer-checked:bg-purple-500/20 peer-checked:text-purple-400 peer-checked:border-purple-500/50 peer-checked:shadow-[0_0_10px_rgba(168,85,247,0.3)] transition-all hover:bg-[#323b46]">Đã Lên Lịch</div>
            </label>
            <label class="cursor-pointer group">
                <input class="peer sr-only" name="status" type="radio" onclick="filterStatus('expired')" />
                <div class="px-4 py-2 rounded-lg bg-[#283039] text-[#9cabba] text-sm font-bold border border-transparent peer-checked:bg-red-500/20 peer-checked:text-red-400 peer-checked:border-red-500/50 transition-all hover:bg-[#323b46]">Đã Hết Hạn</div>
            </label>
        </div>
    </div>
    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-[#283039] shadow-2xl">
        <table class="w-full text-left border-collapse" id="promotionTable">
            <thead>
                <tr class="bg-[#111418] text-xs uppercase text-[#9cabba] font-bold tracking-wider border-b border-[#283039]">
                    <th class="p-5 w-12 text-center">
                        <div class="flex items-center justify-center">
                             <input class="rounded border-[#3b4754] bg-[#283039] text-primary focus:ring-offset-[#111418] size-4" type="checkbox" />
                        </div>
                    </th>
                    <th class="p-5">Sản Phẩm</th>
                    <th class="p-5">Mức Giảm</th>
                    <th class="p-5">Thời Gian</th>
                    <th class="p-5">Trạng Thái</th>
                    <th class="p-5 text-right">Hành Động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#283039] text-sm">
                @foreach (var item in Model)
                {
                    <tr class="bg-[#1a2027] hover:bg-[#202830] transition-all duration-200 group promotion-row hover:shadow-lg hover:z-10 relative border-l-2 border-l-transparent hover:border-l-primary" 
                        data-status="@(item.IsActive ? "active" : (item.StartDate > DateTime.Now ? "scheduled" : "expired"))">
                        <td class="p-5 text-center">
                            <div class="flex items-center justify-center">
                                <input class="rounded border-[#3b4754] bg-[#283039] text-primary focus:ring-offset-[#111418] size-4" type="checkbox" />
                            </div>
                        </td>
                        <td class="p-5">
                            <div class="flex items-center gap-4">
                                <div class="size-12 rounded-xl bg-gradient-to-br from-[#283039] to-[#1a2027] flex items-center justify-center text-primary border border-[#3b4754] shadow-inner group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined">inventory_2</span>
                                </div>
                                <div>
                                    <p class="font-bold text-white text-base group-hover:text-primary transition-colors">@item.Product?.Name</p>
                                    <p class="text-xs text-gray-500 mt-0.5">Mã: #@item.Id</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-5">
                            <div class="flex items-center gap-2">
                                <span class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400 drop-shadow-[0_0_10px_rgba(168,85,247,0.3)]">
                                    @item.DiscountPercent%
                                </span>
                                <span class="text-xs font-bold text-gray-500 uppercase border border-gray-700 px-1 rounded">OFF</span>
                            </div>
                        </td>
                        <td class="p-5">
                            <div class="flex flex-col gap-1.5">
                                <div class="flex items-center gap-2 text-white font-medium">
                                    <span class="material-symbols-outlined text-[16px] text-primary">calendar_today</span>
                                    @item.StartDate.ToString("dd/MM/yyyy")
                                </div>
                                <div class="flex items-center gap-2 text-gray-500 text-xs">
                                    <span class="material-symbols-outlined text-[16px]">arrow_right_alt</span>
                                    @item.EndDate.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </td>
                        <td class="p-5">
                            @if (item.IsActive)
                            {
                                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-accent-green/10 text-accent-green border border-accent-green/20 shadow-[0_0_10px_rgba(34,197,94,0.2)]">
                                    <span class="relative flex h-2 w-2">
                                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
                                      <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
                                    </span>
                                    Đang Chạy
                                </div>
                            }
                            else if (item.StartDate > DateTime.Now)
                            {
                                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-primary/10 text-primary border border-primary/20">
                                    <span class="material-symbols-outlined text-[14px]">schedule</span>
                                    Sắp Diễn Ra
                                </div>
                            }
                            else
                            {
                                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-gray-500/10 text-gray-500 border border-gray-500/20">
                                    <span class="material-symbols-outlined text-[14px]">event_busy</span>
                                    Đã Hết Hạn
                                </div>
                            }
                        </td>
                        <td class="p-5 text-right">
                             <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
                                <button onclick="openUpdateModal('@Url.Action("Update", "Promotion", new { id = item.Id })')" class="size-9 flex items-center justify-center rounded-lg text-[#9cabba] hover:text-white hover:bg-gradient-to-r hover:from-primary hover:to-blue-600 hover:shadow-neon-sm transition-all" title="Chỉnh sửa">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                                <form action="@Url.Action("Delete", "Promotion", new { id = item.Id })" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khuyến mãi này không?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="size-9 flex items-center justify-center rounded-lg text-[#9cabba] hover:text-white hover:bg-gradient-to-r hover:from-red-500 hover:to-pink-600 hover:shadow-[0_0_10px_rgba(248,113,113,0.5)] transition-all" title="Xóa">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Container -->
<div id="createPromotionModal" class="fixed inset-0 z-50 hidden">
    <!-- Blur Overlay -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity opacity-0" id="modalOverlay" onclick="closeCreateModal()"></div>
    <!-- Modal Content -->
    <div class="absolute inset-0 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative w-full max-w-4xl transform transition-all scale-95 opacity-0" id="modalContent">
                <!-- Content will be loaded here -->
            </div>
        </div>
    </div>
</div>

<script>
    function loadContent(url) {
        // This is still used for Update/Delete if we want to keep them as full page replacements or if we want to change them to modals too.
        // For now, I'll leave it as is for Update, but for Create we use openCreateModal.
        // Ideally Update should also use the modal, but the user specifically asked for "Promotion/Create" as a window.
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(response => response.text())
            .then(html => {
                var container = document.getElementById('dashboard-content');
                if (container) {
                    container.innerHTML = html;
                    
                     // Re-execute scripts
                    container.querySelectorAll('script').forEach(oldScript => {
                        const newScript = document.createElement('script');
                        Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                        newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                        oldScript.parentNode.replaceChild(newScript, oldScript);
                    });
                }
            })
            .catch(error => console.error('Error loading content:', error));
    }

    function openUpdateModal(url) {
        var modal = document.getElementById('createPromotionModal');
        var overlay = document.getElementById('modalOverlay');
        var content = document.getElementById('modalContent');
        
        // Show modal container
        modal.classList.remove('hidden');
        
        // Load content
        fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            content.innerHTML = html;
            
            // Re-init GSAP
            if (typeof initDashboardAnimations === 'function') initDashboardAnimations();
            if (typeof initGlobalAnimations === 'function') initGlobalAnimations();

            // Animate in
            setTimeout(() => {
                overlay.classList.remove('opacity-0');
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        });
    }

    function openCreateModal() {
        var modal = document.getElementById('createPromotionModal');
        var overlay = document.getElementById('modalOverlay');
        var content = document.getElementById('modalContent');
        
        // Show modal container
        modal.classList.remove('hidden');
        
        // Load content
        fetch('@Url.Action("Create", "Promotion")', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            content.innerHTML = html;
            
            // Re-init GSAP
            if (typeof initDashboardAnimations === 'function') initDashboardAnimations();
            if (typeof initGlobalAnimations === 'function') initGlobalAnimations();

            // Animate in
            setTimeout(() => {
                overlay.classList.remove('opacity-0');
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        });
    }

    function closeCreateModal() {
        var modal = document.getElementById('createPromotionModal');
        var overlay = document.getElementById('modalOverlay');
        var content = document.getElementById('modalContent');
        
        // Animate out
        overlay.classList.add('opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        content.classList.add('scale-95', 'opacity-0');
        
        setTimeout(() => {
            modal.classList.add('hidden');
            content.innerHTML = '';
        }, 300);
    }

    function submitCreateForm(event) {
        event.preventDefault();
        var form = event.target;
        var formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text()) // Expecting partial view (updated list) or form with errors
        .then(html => {
             // Check if it's the dashboard list (success) or the form again (validation error)
             // A simple heuristic is checking for a specific element unique to the list or form.
             // Or better: the controller currently returns the list partial on success.
             
             if (html.includes("Promotion Management")) {
                 // Success - reload the dashboard content
                 closeCreateModal();
                 var container = document.getElementById('dashboard-content');
                 container.innerHTML = html;
                 
                  // Re-execute scripts for the dashboard
                 container.querySelectorAll('script').forEach(oldScript => {
                    const newScript = document.createElement('script');
                    Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                    newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                    oldScript.parentNode.replaceChild(newScript, oldScript);
                });

                 // Re-init GSAP
                 if (typeof initDashboardAnimations === 'function') {
                     initDashboardAnimations();
                 }
             } else {
                 // Failure - replace modal content with the returned form (with errors)
                 var content = document.getElementById('modalContent');
                 content.innerHTML = html;
             }
        })
        .catch(error => console.error('Error:', error));
        
        return false;
    }

    function searchPromotions() {
        var input, filter, table, tr, td, i, txtValue;
        input = document.getElementById("promotionSearch");
        filter = input.value.toUpperCase();
        table = document.getElementById("promotionTable");
        tr = table.getElementsByTagName("tr");
        for (i = 0; i < tr.length; i++) {
            td = tr[i].getElementsByTagName("td")[1]; // Search by Product Name (Index 1)
            if (td) {
                txtValue = td.textContent || td.innerText;
                if (txtValue.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    function filterStatus(status) {
        var table = document.getElementById("promotionTable");
        var tr = table.getElementsByTagName("tr");
        
        for (var i = 1; i < tr.length; i++) { // Start from 1 to skip header
            var row = tr[i];
            var rowStatus = row.getAttribute('data-status');
            
            if (status === 'all') {
                row.style.display = "";
            } else {
                if (rowStatus === status) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            }
        }
    }
</script>