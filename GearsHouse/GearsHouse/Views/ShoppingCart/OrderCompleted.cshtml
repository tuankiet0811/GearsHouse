@model int

@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
    Layout = "_Layout";
}

@section Styles {
    <style>
        /* Page Loader Overlay */
        .page-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: #0B0E14;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transform-origin: top;
        }

        .loader-content {
            overflow: hidden;
        }

        .loader-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3rem;
            font-weight: 900;
            color: #0d7ff2;
            text-transform: uppercase;
            transform: translateY(100%);
        }

        .glass-panel {
            background: rgba(19, 22, 28, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            opacity: 0; /* Hidden initially for GSAP */
            transform: scale(0.9);
        }
        
        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        
        @@keyframes check-bounce {
            0% { transform: scale(0); opacity: 0; }
            50% { transform: scale(1.2); opacity: 1; }
            70% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }

        @@keyframes wallet-pulse {
            0% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(13, 127, 242, 0)); }
            50% { transform: scale(1.05); filter: drop-shadow(0 0 20px rgba(13, 127, 242, 0.3)); }
            100% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(13, 127, 242, 0)); }
        }

        .animate-float {
            animation: float 3s ease-in-out infinite;
        }
        
        .animate-check {
            animation: check-bounce 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            animation-delay: 0.3s;
            opacity: 0;
        }

        .animate-wallet {
            animation: wallet-pulse 2s ease-in-out infinite;
        }

        .bg-grid-pattern {
            background-image: linear-gradient(rgba(13, 127, 242, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(13, 127, 242, 0.05) 1px, transparent 1px);
            background-size: 30px 30px;
        }
    </style>
}

<div class="min-h-[80vh] flex items-center justify-center p-4 bg-[#0B0E14] relative overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-grid-pattern"></div>
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-primary/10 rounded-full blur-[100px] animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-accent-purple/10 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1s;"></div>

    <div class="glass-panel border border-border-dark rounded-3xl p-8 md:p-12 max-w-lg w-full text-center relative z-10 shadow-[0_0_50px_rgba(0,0,0,0.5)]">
        <!-- Success Animation Container -->
        <div class="relative w-40 h-40 mx-auto mb-8">
            <!-- Glowing Circle Background -->
            <div class="absolute inset-0 bg-primary/10 rounded-full blur-xl animate-pulse"></div>
            
            <!-- Wallet Icon -->
            <div class="absolute inset-0 flex items-center justify-center animate-float">
                <span class="material-symbols-outlined text-[8rem] text-primary drop-shadow-[0_0_15px_rgba(13,127,242,0.5)] animate-wallet">
                    account_balance_wallet
                </span>
            </div>

            <!-- Checkmark Badge -->
            <div class="absolute -bottom-2 -right-2 w-14 h-14 bg-green-500 rounded-full border-4 border-[#0B0E14] flex items-center justify-center shadow-lg animate-check">
                <span class="material-symbols-outlined text-3xl text-white font-bold">check</span>
            </div>
            
            <!-- Decorative Particles -->
            <div class="absolute top-0 right-0 w-3 h-3 bg-yellow-400 rounded-full animate-ping" style="animation-duration: 2s;"></div>
            <div class="absolute bottom-10 left-0 w-2 h-2 bg-primary rounded-full animate-ping" style="animation-duration: 1.5s; animation-delay: 0.5s;"></div>
        </div>

        <!-- Text Content -->
        <h1 class="text-3xl md:text-4xl font-black text-white uppercase tracking-tight mb-2 gsap-reveal">
            Đơn Hàng <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-cyan">Thành Công</span>
        </h1>
        <p class="text-slate-400 mb-6 gsap-reveal">Cảm ơn quý khách đã mua hàng.</p>

        <!-- Order Details Box -->
        <div class="bg-[#181c22]/80 border border-border-dark rounded-xl p-6 mb-8 backdrop-blur-sm relative overflow-hidden group gsap-reveal">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
            
            <p class="text-sm text-slate-500 uppercase tracking-widest mb-1">Mã Đơn Hàng</p>
            <div class="text-3xl font-mono font-bold text-white flex items-center justify-center gap-3">
                <span class="text-primary">#</span>@Model
                <button onclick="navigator.clipboard.writeText('#@Model')" class="text-slate-600 hover:text-white transition-colors" title="Sao chép mã">
                    <span class="material-symbols-outlined text-lg">content_copy</span>
                </button>
            </div>
            <p class="text-xs text-slate-500 mt-2">Email xác nhận đã được gửi đến hộp thư của quý khách.</p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center gsap-reveal">
            <a asp-controller="Home" asp-action="Index" class="group relative overflow-hidden rounded-xl bg-surface-dark border border-border-dark py-3 px-6 text-slate-300 transition-all hover:text-white hover:border-primary hover:shadow-[0_0_20px_rgba(13,127,242,0.2)] flex items-center justify-center gap-2">
                <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
                <span>Về Trang Chủ</span>
            </a>
            
            <a asp-controller="Product" asp-action="Index" class="group relative overflow-hidden rounded-xl bg-primary py-3 px-8 text-white shadow-[0_0_20px_rgba(13,127,242,0.4)] transition-all hover:shadow-[0_0_30px_rgba(13,127,242,0.6)] hover:-translate-y-1 active:scale-[0.98] flex items-center justify-center gap-2">
                <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20"></div>
                <span class="relative z-10 font-bold tracking-wide">Tiếp Tục Mua Sắm</span>
                <span class="material-symbols-outlined relative z-10 group-hover:translate-x-1 transition-transform">shopping_cart</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", (event) => {
            gsap.registerPlugin();

            const tl = gsap.timeline({ defaults: { ease: "power4.out" } });

            // 1. Initial State set in CSS (opacity 0 for glass-panel)
            // But let's ensure specificity for inner elements
            gsap.set(".gsap-reveal", { y: 50, opacity: 0 });

            // 2. Loader Animation
            tl.to(".loader-text", {
                y: 0,
                duration: 1,
                ease: "power4.out",
                delay: 0.2
            })
            .to(".loader-text", {
                y: -100,
                duration: 0.8,
                ease: "power2.in",
                delay: 0.5
            })
            .to(".page-loader", {
                scaleY: 0,
                transformOrigin: "top",
                duration: 1,
                ease: "expo.inOut"
            }, "-=0.3") // Overlap with text exit
            
            // 3. Main Content Entrance
            .to(".glass-panel", {
                opacity: 1,
                scale: 1,
                duration: 1.2,
                ease: "elastic.out(1, 0.75)"
            }, "-=0.5") // Start before loader finishes completely
            
            // 4. Staggered Elements
            .to(".gsap-reveal", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.15,
                ease: "power2.out"
            }, "-=0.8");
            
            // 5. Success Checkmark Pop (after main reveal)
            tl.fromTo(".animate-check", 
                { scale: 0, opacity: 0, rotation: -45 },
                { scale: 1, opacity: 1, rotation: 0, duration: 0.6, ease: "back.out(1.7)" },
                "-=0.4"
            );
        });

        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d7ff2",
                        "primary-glow": "#0d7ff2aa",
                        "accent-purple": "#a855f7",
                        "accent-cyan": "#06b6d4",
                        "background-dark": "#0B0E14",
                        "surface-dark": "#13161C",
                        "border-dark": "#1f2937",
                    },
                    fontFamily: {
                        "display": ["Space Grotesk", "sans-serif"],
                        "body": ["Noto Sans", "sans-serif"],
                    },
                },
            },
        }
    </script>
}
