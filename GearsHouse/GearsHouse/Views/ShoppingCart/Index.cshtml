@model GearsHouse.Models.ShoppingCart
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="layout-container flex flex-col items-center py-8">
    <div class="w-full max-w-[1200px] px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-2 py-4 mb-2">
            <a class="text-text-muted hover:text-accent-cyan transition-colors text-sm font-medium leading-normal flex items-center gap-1" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined text-[16px]">home</span>
                Trang chủ
            </a>
            <span class="text-text-muted text-sm font-medium leading-normal">/</span>
            <span class="text-white text-sm font-medium leading-normal">Giỏ hàng</span>
        </div>
        <div class="flex flex-col gap-1 mb-8">
            <h1 class="text-white text-4xl sm:text-5xl font-black leading-tight tracking-tight uppercase">Giỏ hàng của bạn</h1>
            <p class="text-accent-cyan text-lg font-medium tracking-wide drop-shadow-[0_0_5px_rgba(6,182,212,0.5)]">@Model.Items.Sum(i => i.Quantity) sản phẩm // Sẵn sàng triển khai</p>
        </div>
        
        @if (!Model.Items.Any())
        {
             <div class="text-center py-12">
                <p class="text-white text-xl mb-4">Giỏ hàng trống</p>
                <a asp-controller="Product" asp-action="Index" class="inline-block px-6 py-3 bg-accent-purple text-white font-bold rounded-lg hover:bg-accent-purple/80 transition-colors">Mua sắm ngay</a>
            </div>
        }
        else
        {
            <div class="flex flex-col lg:flex-row gap-8 items-start">
                <div class="flex-1 w-full flex flex-col gap-4">
                    <div class="hidden sm:flex justify-between px-6 pb-2 text-xs uppercase tracking-wider text-text-muted font-bold border-b border-border-dark">
                        <div class="w-1/2">Sản phẩm</div>
                        <div class="w-1/4 text-center">Số lượng</div>
                        <div class="w-1/4 text-right">Giá</div>
                    </div>
                    
                    @foreach (var item in Model.Items)
                    {
                        <div class="group relative flex flex-col sm:flex-row gap-4 bg-surface-dark hover:bg-[#22262d] border border-border-dark hover:border-accent-purple/50 hover:shadow-neon-purple transition-all duration-300 rounded-xl p-4 sm:items-center">
                            <div class="flex items-start gap-4 flex-1">
                                <div class="relative shrink-0 overflow-hidden rounded-lg border border-border-dark group-hover:border-accent-purple transition-colors size-[90px]">
                                    <div class="bg-center bg-no-repeat bg-cover w-full h-full transform group-hover:scale-110 transition-transform duration-500" style='background-image: url("@item.ImageUrl");'></div>
                                </div>
                                <div class="flex flex-col justify-center h-full py-1">
                                    <p class="text-white text-lg font-bold leading-tight mb-1 group-hover:text-accent-purple transition-colors">@item.Name</p>
                                    <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="mt-2 text-accent-red hover:text-accent-red/80 text-xs font-bold uppercase tracking-wider flex items-center gap-1 w-fit transition-colors sm:hidden">
                                        <span class="material-symbols-outlined text-[14px]">delete</span> Xóa
                                    </a>
                                </div>
                            </div>
                            <div class="flex justify-between items-center w-full sm:w-auto sm:contents">
                                <div class="flex items-center justify-center sm:w-1/4">
                                    <div class="flex items-center bg-background-dark rounded-lg border border-border-dark group-hover:border-accent-purple/30 transition-colors">
                                        <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-change="-1" class="text-white hover:text-accent-cyan transition-colors h-8 w-8 flex items-center justify-center rounded-l-lg hover:bg-white/5 active:bg-white/10 @(item.Quantity <= 1 ? "opacity-50 cursor-not-allowed pointer-events-none" : "")">
                                            <span class="material-symbols-outlined text-[16px]">remove</span>
                                        </a>
                                        <input class="w-10 bg-transparent text-center text-white font-medium focus:outline-none appearance-none [&::-webkit-inner-spin-button]:appearance-none" readonly type="number" value="@item.Quantity" />
                                        <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-change="1" class="text-white hover:text-accent-cyan transition-colors h-8 w-8 flex items-center justify-center rounded-r-lg hover:bg-white/5 active:bg-white/10">
                                            <span class="material-symbols-outlined text-[16px]">add</span>
                                        </a>
                                    </div>
                                </div>
                                <div class="flex flex-col items-end justify-center sm:w-1/4 gap-2">
                                    <p class="text-white text-xl font-bold tracking-tight group-hover:text-accent-cyan transition-colors drop-shadow-[0_0_2px_rgba(6,182,212,0.3)]">
                                        @item.Price.ToString("#,##0") đ
                                    </p>
                                    @if (item.Price < item.OriginalPrice)
                                    {
                                        <p class="text-text-muted text-sm line-through">@item.OriginalPrice.ToString("#,##0") đ</p>
                                    }
                                    <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="hidden sm:flex text-text-muted hover:text-accent-red transition-colors text-xs font-medium items-center gap-1 group/remove">
                                        <span class="material-symbols-outlined text-[16px] group-hover/remove:fill-current">delete</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="w-full lg:w-[380px] shrink-0">
                    <div class="sticky top-24 bg-surface-dark border border-border-dark rounded-2xl p-6 shadow-xl relative overflow-hidden group/summary">
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-accent-purple/10 rounded-full blur-3xl pointer-events-none group-hover/summary:bg-accent-purple/20 transition-all duration-700"></div>
                        <h3 class="text-white text-xl font-bold uppercase tracking-wider mb-6 border-b border-border-dark pb-4 relative z-10">Tổng đơn hàng</h3>
                        <div class="flex flex-col gap-4 mb-6 relative z-10">
                            <div class="flex justify-between items-center">
                                <p class="text-text-muted text-sm font-medium">Tạm tính</p>
                                <p class="text-white text-base font-bold">@Model.Items.Sum(i => i.Price * i.Quantity).ToString("#,##0") đ</p>
                            </div>
                            <div class="flex justify-between items-center">
                                <p class="text-text-muted text-sm font-medium">Vận chuyển</p>
                                <p class="text-emerald-400 text-base font-bold uppercase text-xs tracking-wider shadow-emerald-500/20 drop-shadow-sm">Miễn phí</p>
                            </div>
                        </div>
                        
                        <div class="border-t border-border-dark border-dashed my-2 relative z-10"></div>
                        <div class="flex justify-between items-end my-6 relative z-10">
                            <p class="text-white text-lg font-bold">Tổng cộng</p>
                            <div class="text-right">
                                <p class="text-3xl font-black text-white tracking-tighter leading-none group-hover/summary:text-accent-cyan transition-colors duration-300 drop-shadow-[0_0_8px_rgba(6,182,212,0.3)]">
                                    @Model.Items.Sum(i => i.Price * i.Quantity).ToString("#,##0") đ
                                </p>
                                <p class="text-xs text-text-muted mt-1">VNĐ</p>
                            </div>
                        </div>
                        <a asp-action="Checkout" class="w-full bg-accent-purple hover:bg-accent-purple/90 text-white font-bold text-lg py-4 rounded-xl shadow-neon-purple hover:shadow-neon-purple-hover transition-all duration-300 transform hover:-translate-y-0.5 flex items-center justify-center gap-2 group relative z-10 overflow-hidden">
                            <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></span>
                            Thanh toán
                            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                        <div class="mt-6 flex justify-center gap-4 text-text-muted opacity-50 relative z-10">
                            <span class="material-symbols-outlined text-[24px]">lock</span>
                            <span class="text-xs font-medium">Thanh toán bảo mật</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>