@model GearsHouse.Models.Order

@{
    ViewData["Title"] = "Checkout";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .cyber-input:focus {
            box-shadow: 0 0 0 1px #0d7ff2, 0 0 15px rgba(13, 127, 242, 0.4);
            border-color: #0d7ff2;
        }

        .cyber-card-selected {
            border-color: #0d7ff2 !important;
            box-shadow: inset 0 0 20px rgba(13, 127, 242, 0.3), 0 0 15px rgba(13, 127, 242, 0.2);
            background-color: rgba(13, 127, 242, 0.05);
        }

        .glitch-hover:hover {
            text-shadow: 2px 0 #0d7ff2, -2px 0 #ef4444;
        }

        .glass-panel {
            background: rgba(19, 22, 28, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        
        /* Custom scrollbar for order list */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #0B0E14;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #283039;
            border-radius: 3px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #0d7ff2;
        }
    </style>
}

<div class="flex-grow layout-container flex flex-col items-center py-12 px-4 md:px-8 lg:px-16 w-full max-w-[1600px] mx-auto">
    <div class="w-full mb-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-border-dark pb-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-primary/10 text-primary border border-primary/20 uppercase tracking-widest">HỆ THỐNG BẢO MẬT</span>
                <div class="h-px w-12 bg-border-dark"></div>
            </div>
            <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-2 glitch-hover cursor-default">
                THANH <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-cyan">TOÁN</span>
            </h1>
            <p class="text-slate-400 max-w-lg">Hoàn tất đơn hàng của bạn. Bảo mật cấp độ: <span class="text-accent-cyan">Tối đa</span>.</p>
        </div>
        <div class="flex flex-col items-end gap-2">
            <div class="flex items-center gap-4 text-sm font-mono tracking-wider">
                <span class="text-slate-600">GIỎ HÀNG</span>
                <span class="text-primary font-bold drop-shadow-[0_0_5px_rgba(13,127,242,0.8)]">THANH TOÁN</span>
                <span class="text-slate-600">XÁC NHẬN</span>
            </div>
            <div class="flex gap-1">
                <div class="h-1.5 w-12 bg-border-dark rounded-full"></div>
                <div class="h-1.5 w-12 bg-primary rounded-full shadow-[0_0_10px_theme('colors.primary')]"></div>
                <div class="h-1.5 w-12 bg-border-dark rounded-full"></div>
            </div>
        </div>
    </div>

    <form asp-action="Checkout" method="post" id="checkoutForm" class="w-full grid grid-cols-1 lg:grid-cols-2 gap-8 xl:gap-16">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="OrderDate" />
        <input type="hidden" asp-for="ShippingAddress" id="shippingHidden" />

        <!-- LEFT COLUMN: ORDER SUMMARY -->
        <div class="flex flex-col gap-6 order-2 lg:order-1 h-full">
            <div class="glass-panel border border-border-dark rounded-2xl overflow-hidden shadow-2xl sticky top-28 backdrop-blur-xl">
                <div class="p-6 border-b border-border-dark bg-[#181c22]/50 flex justify-between items-center">
                    <h2 class="text-xl font-bold text-white tracking-widest flex items-center gap-3 uppercase">
                        <span class="material-symbols-outlined text-primary">inventory_2</span>
                        Đơn Hàng
                    </h2>
                    <span class="text-xs font-mono text-slate-500 bg-[#0B0E14] px-2 py-1 rounded border border-border-dark">ID: #@Model.Id</span>
                </div>
                <div class="p-6 flex flex-col gap-6 max-h-[500px] overflow-y-auto custom-scrollbar">
                    @foreach (var item in Model.OrderDetails)
                    {
                        <div class="flex gap-5 items-center group p-3 rounded-xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                            <div class="relative w-24 h-24 rounded-lg overflow-hidden border border-border-dark group-hover:border-primary transition-all duration-300 shadow-lg group-hover:shadow-[0_0_15px_rgba(13,127,242,0.15)]">
                                <div class="absolute inset-0 bg-cover bg-center transform group-hover:scale-110 transition-transform duration-500" style="background-image: url('@(item.Product?.ImageUrl ?? item.Product.ImageUrl)');"></div>
                            </div>
                            <div class="flex-1">
                                <div class="flex justify-between items-start mb-1">
                                    <h3 class="text-white font-bold text-lg group-hover:text-primary transition-colors">@item.Product?.Name</h3>
                                    <p class="text-white font-bold font-mono text-lg">@item.Price.ToString("#,##0") đ</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#0B0E14] border border-border-dark rounded px-2 py-0.5 text-xs font-mono text-slate-400">SL: @item.Quantity</div>
                                </div>
                            </div>
                        </div>
                        <div class="h-px w-full bg-gradient-to-r from-transparent via-border-dark to-transparent"></div>
                    }
                </div>
                <div class="p-6 bg-surface-darker border-t border-border-dark space-y-4 relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#1f2937 1px, transparent 1px), linear-gradient(90deg, #1f2937 1px, transparent 1px); background-size: 20px 20px;"></div>
                    <div class="relative z-10 space-y-3">
                        <div class="flex justify-between text-slate-400 text-sm">
                            <span>Tạm tính</span>
                            <span class="font-mono text-white">@Model.OrderDetails.Sum(i => i.Price * i.Quantity).ToString("#,##0") đ</span>
                        </div>
                        
                        <div class="flex justify-between text-accent-cyan text-sm py-2 px-3 bg-accent-cyan/10 rounded border border-accent-cyan/20" id="discountSection" style="display:none;">
                            <span class="flex items-center gap-2 font-bold"><span class="material-symbols-outlined text-[18px]">local_offer</span> GIẢM GIÁ</span>
                            <span class="font-mono font-bold" id="discountAmount">-0 đ</span>
                        </div>

                        <div class="flex justify-between text-slate-400 text-sm">
                            <span>Vận chuyển</span>
                            <span class="font-mono text-slate-500 text-xs italic">Miễn phí</span>
                        </div>
                    </div>
                    <div class="h-px bg-border-dark my-4 relative z-10"></div>
                    <div class="relative z-10 flex justify-between items-center bg-[#0B0E14] p-4 rounded-xl border border-primary/30 shadow-[0_0_20px_rgba(13,127,242,0.1)]">
                        <div class="flex flex-col">
                            <span class="text-slate-400 text-xs uppercase tracking-widest mb-1">Tổng cộng</span>
                            <span class="text-xs text-slate-600">Đã bao gồm thuế</span>
                        </div>
                        <span class="text-4xl font-black text-white drop-shadow-[0_0_15px_rgba(13,127,242,0.6)] font-display tracking-tight" id="finalTotal">@Model.TotalPrice.ToString("#,##0") đ</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: FORM -->
        <div class="flex flex-col gap-8 order-1 lg:order-2">
            <section class="glass-panel border border-border-dark rounded-2xl p-6 lg:p-8 relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
                <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <h2 class="text-xl font-bold text-white mb-8 flex items-center gap-4 border-b border-border-dark pb-4">
                    <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary border border-primary/30 shadow-[0_0_10px_rgba(13,127,242,0.2)]">
                        <span class="material-symbols-outlined">local_shipping</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="uppercase tracking-wider text-sm text-primary font-bold">Bước 1</span>
                        <span>Thông Tin Giao Hàng</span>
                    </div>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2 space-y-2">
                        <label asp-for="FullName" class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Họ và Tên</label>
                        <input asp-for="FullName" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-3.5 text-white focus:outline-none cyber-input transition-all placeholder-slate-700" placeholder="VD: Nguyễn Văn A" required />
                        <span asp-validation-for="FullName" class="text-accent-red text-xs"></span>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="PhoneNumber" class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Số Điện Thoại</label>
                        <input asp-for="PhoneNumber" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-3.5 text-white focus:outline-none cyber-input transition-all placeholder-slate-700" placeholder="(+84) ..." required />
                        <span asp-validation-for="PhoneNumber" class="text-accent-red text-xs"></span>
                    </div>
                    
                    <div class="md:col-span-2 space-y-2">
                        <label class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Địa chỉ (Số nhà, Đường)</label>
                        <div class="relative group/input">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-600 group-focus-within/input:text-primary transition-colors">home_pin</span>
                            <input id="streetInput" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg pl-10 pr-4 py-3.5 text-white focus:outline-none cyber-input transition-all placeholder-slate-700" placeholder="Số nhà, tên đường..." type="text" required />
                        </div>
                    </div>
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Tỉnh / Thành phố</label>
                        <div class="relative group/select">
                            <select id="provinceSelect" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-3.5 text-white focus:outline-none cyber-input appearance-none cursor-pointer">
                                <option value="">Chọn Tỉnh / Thành</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-500 group-hover/select:text-primary transition-colors">expand_more</span>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Quận / Huyện</label>
                        <div class="relative group/select">
                            <select id="districtSelect" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-3.5 text-white focus:outline-none cyber-input appearance-none cursor-pointer" disabled>
                                <option value="">Chọn Quận / Huyện</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-500 group-hover/select:text-primary transition-colors">expand_more</span>
                        </div>
                    </div>
                    
                    @* Ward selection removed as requested *@

                    <div class="md:col-span-2 space-y-2">
                        <label asp-for="Notes" class="block text-xs font-bold uppercase text-slate-400 tracking-wider ml-1">Ghi Chú Đơn Hàng</label>
                        <textarea asp-for="Notes" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-3 text-white focus:outline-none cyber-input transition-all placeholder-slate-700 resize-none min-h-[80px]" placeholder="Ghi chú giao hàng..." rows="2"></textarea>
                    </div>
                </div>
            </section>
            
            <section class="glass-panel border border-border-dark rounded-2xl p-6 lg:p-8 relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
                <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-primary opacity-50 group-hover:opacity-100 transition-opacity"></div>
                <h2 class="text-xl font-bold text-white mb-8 flex items-center gap-4 border-b border-border-dark pb-4">
                    <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary border border-primary/30 shadow-[0_0_10px_rgba(13,127,242,0.2)]">
                        <span class="material-symbols-outlined">payments</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="uppercase tracking-wider text-sm text-primary font-bold">Bước 2</span>
                        <span>Phương Thức Thanh Toán</span>
                    </div>
                </h2>
                
                <!-- COUPON SECTION -->
                <div class="mb-8 p-5 bg-surface-darker border border-dashed border-border-dark rounded-xl relative overflow-hidden">
                    <div class="absolute -right-10 -top-10 w-20 h-20 bg-accent-purple/10 blur-2xl rounded-full"></div>
                    <label class="block text-xs font-bold uppercase text-slate-400 mb-3 tracking-wider flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm text-accent-purple">loyalty</span>
                        Mã Giảm Giá / Voucher
                    </label>
                    <div class="flex gap-3">
                        <input asp-for="CouponCode" id="couponInput" class="flex-1 bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-2.5 text-white focus:outline-none cyber-input font-mono uppercase text-sm tracking-widest placeholder-slate-700" placeholder="NHẬP MÃ" type="text" />
                        <button type="button" onclick="applyCoupon()" class="relative overflow-hidden bg-accent-purple/10 hover:bg-accent-purple/20 text-accent-purple border border-accent-purple/50 hover:border-accent-purple px-6 py-2 rounded-lg font-bold text-sm transition-all shadow-[0_0_15px_rgba(168,85,247,0.1)] hover:shadow-[0_0_20px_rgba(168,85,247,0.3)] group/btn">
                            <span class="relative z-10 flex items-center gap-2">
                                ÁP DỤNG <span class="material-symbols-outlined text-base">check_circle</span>
                            </span>
                        </button>
                    </div>
                     <div id="couponMessage" class="mt-2 text-xs"></div>
                </div>

                <label class="block text-xs font-bold uppercase text-slate-400 mb-4 tracking-wider ml-1">Chọn Phương Thức Thanh Toán</label>
                <div class="mb-8">
                    <!-- Dropdown Selection -->
                    <div class="relative group/select mb-6">
                        <select asp-for="PaymentMethod" id="paymentMethodSelect" onchange="updatePaymentPreview()" class="w-full bg-[#0B0E14] border border-border-dark rounded-lg px-4 py-4 text-white focus:outline-none cyber-input appearance-none cursor-pointer text-base">
                            <option value="VNPay">VNPay - Thanh toán qua VNPAY-QR, Thẻ nội địa/quốc tế</option>
                            <option value="MoMo">MoMo - Ví điện tử MoMo</option>
                            <option value="COD">COD - Thanh toán khi nhận hàng (Cash On Delivery)</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-500 group-hover/select:text-primary transition-colors">expand_more</span>
                    </div>

                    <!-- Dynamic Preview Container -->
                    <div id="paymentPreview" class="p-6 bg-[#0B0E14] border border-border-dark rounded-xl flex items-center gap-6 transition-all duration-300 relative overflow-hidden group">
                         <!-- Background Glow -->
                        <div id="previewGlow" class="absolute inset-0 bg-primary/5 opacity-0 transition-opacity duration-300"></div>
                        
                        <!-- Icon/Logo Container -->
                        <div id="previewIconContainer" class="w-20 h-20 rounded-lg bg-white p-3 flex items-center justify-center shadow-lg relative z-10 transition-transform duration-300 group-hover:scale-105">
                             <img id="previewImage" src="https://vnpay.vn/assets/images/logo-icon/logo-primary.svg" alt="Payment Logo" class="w-full h-full object-contain" />
                        </div>
                        
                        <!-- Text Info -->
                        <div class="flex-1 relative z-10">
                            <h3 id="previewTitle" class="text-lg font-bold text-white mb-1">VNPay Wallet</h3>
                            <p id="previewDesc" class="text-sm text-slate-400">Thanh toán an toàn, nhanh chóng qua cổng VNPay.</p>
                        </div>

                        <!-- Checkmark -->
                         <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary text-primary flex items-center justify-center relative z-10 shadow-[0_0_10px_theme('colors.primary')]">
                             <span class="material-symbols-outlined text-lg font-bold">check</span>
                         </div>
                    </div>
                </div>
                
                @* Removed Dummy Credit Card Form as we use VNPay/MoMo/COD *@
            </section>
            
            <button type="submit" onclick="prepareShippingAddress()" class="group relative w-full overflow-hidden rounded-xl bg-primary py-5 px-8 text-white shadow-[0_0_20px_rgba(13,127,242,0.4)] transition-all hover:shadow-[0_0_40px_rgba(13,127,242,0.6)] hover:-translate-y-1 active:scale-[0.98] active:translate-y-0 flex items-center justify-center gap-4">
                <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20"></div>
                <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/30 to-transparent group-hover:animate-[shimmer_1.5s_infinite]"></div>
                <span class="material-symbols-outlined animate-pulse text-3xl">bolt</span>
                <span class="text-xl font-black tracking-[0.2em] uppercase relative z-10">Đặt Hàng</span>
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </button>
            <p class="text-center text-xs text-slate-500 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">lock</span>
                Bằng cách nhấn "Đặt Hàng", bạn đồng ý với <a class="text-primary hover:underline hover:text-primary-glow transition-colors" href="#">Điều Khoản Dịch Vụ</a> của chúng tôi. Dữ liệu của bạn được mã hóa 256-bit.
            </p>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d7ff2",
                        "primary-glow": "#0d7ff2aa",
                        "accent-purple": "#a855f7",
                        "accent-cyan": "#06b6d4",
                        "accent-red": "#ef4444",
                        "background-light": "#f5f7f8",
                        "background-dark": "#0B0E14",
                        "surface-dark": "#13161C",
                        "surface-darker": "#0f1216",
                        "border-dark": "#1f2937","border-neon": "#0d7ff2",
                    },
                    fontFamily: {
                        "display": ["Space Grotesk", "sans-serif"],
                        "body": ["Noto Sans", "sans-serif"],
                    },
                    boxShadow: {
                        "neon-blue": "0 0 10px theme('colors.primary'), 0 0 25px theme('colors.primary-glow')",
                        "neon-purple": "0 0 10px theme('colors.accent-purple'), 0 0 25px theme('colors.accent-purple')",
                        "inner-glow": "inset 0 0 20px rgba(13, 127, 242, 0.1)",
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'glow-pulse': 'glowPulse 2s ease-in-out infinite',
                         'shimmer': 'shimmer 1.5s infinite',
                    },
                    keyframes: {
                        glowPulse: {
                            '0%, 100%': { boxShadow: '0 0 5px #0d7ff2, 0 0 10px #0d7ff2' },
                            '50%': { boxShadow: '0 0 15px #0d7ff2, 0 0 25px #0d7ff2' },
                        },
                        shimmer: {
                            '100%': { transform: 'translateX(100%)' }
                        }
                    }
                },
            },
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        // Address Handling using esgoo.net API
        $(document).ready(function () {
            // Fetch Provinces
            $.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function (data_tinh) {
                if (data_tinh.error == 0) {
                    $.each(data_tinh.data, function (key_tinh, val_tinh) {
                        $("#provinceSelect").append('<option value="' + val_tinh.id + '" data-name="' + val_tinh.full_name + '">' + val_tinh.full_name + '</option>');
                    });
                }
            });

            // Fetch Districts
            $("#provinceSelect").change(function (e) {
                var idtinh = $(this).val();
                $("#districtSelect").empty().append('<option value="">Select District</option>').prop('disabled', true);
                
                if (idtinh != "0" && idtinh != "") {
                     $.getJSON('https://esgoo.net/api-tinhthanh/2/' + idtinh + '.htm', function (data_quan) {
                        if (data_quan.error == 0) {
                            $.each(data_quan.data, function (key_quan, val_quan) {
                                $("#districtSelect").append('<option value="' + val_quan.id + '" data-name="' + val_quan.full_name + '">' + val_quan.full_name + '</option>');
                            });
                             $("#districtSelect").prop('disabled', false);
                        }
                    });
                }
            });

            // Ward selection logic removed
            
            // Initialize Payment Preview
            updatePaymentPreview();
        });

        function prepareShippingAddress() {
            var street = $("#streetInput").val();
            // Ward is no longer used
            // var ward = $("#wardSelect option:selected").data("name") || "";
            var district = $("#districtSelect option:selected").data("name") || "";
            var province = $("#provinceSelect option:selected").data("name") || "";

            // Validation without Ward
            if(street && district && province) {
                var fullAddress = street + ", " + district + ", " + province;
                $("#shippingHidden").val(fullAddress);
            } else {
                // Let form validation handle it
            }
        }
        
        // Coupon Logic
         function formatCurrencyVND(value) {
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value).replace('₫', 'đ');
        }

        // Payment Preview Logic
        const paymentMethods = {
            'VNPay': {
                title: 'VNPay Wallet',
                desc: 'Thanh toán an toàn, nhanh chóng qua cổng VNPay.',
                color: '#0d7ff2',
                type: 'img',
                src: 'https://vnpay.vn/assets/images/logo-icon/logo-primary.svg'
            },
            'MoMo': {
                title: 'MoMo E-Wallet',
                desc: 'Thanh toán siêu tốc qua ví điện tử MoMo.',
                color: '#a50064',
                type: 'img',
                src: 'https://developers.momo.vn/v3/assets/images/logo-custom2-57d6118fe524633b89befe8cb63a3956.png'
