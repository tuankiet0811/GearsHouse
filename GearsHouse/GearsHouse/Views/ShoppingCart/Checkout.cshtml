        function updatePaymentPreview() {
            const selected = document.getElementById('paymentMethodSelect').value;
            const data = paymentMethods[selected];
            
            if (!data) return;

            // Update Text
            document.getElementById('previewTitle').innerText = data.title;
            document.getElementById('previewDesc').innerText = data.desc;
            
            // Update Icon/Image
            const container = document.getElementById('previewIconContainer');
            if (data.type === 'img') {
                container.innerHTML = `<img src="${data.src}" alt="${selected}" class="w-full h-full object-contain" />`;
                container.style.backgroundColor = 'white';
                container.style.borderColor = 'transparent';
            } else {
                container.innerHTML = `<span class="material-symbols-outlined text-4xl" style="color: ${data.color}">${data.icon}</span>`;
                container.style.backgroundColor = '#181c22';
                container.style.border = '1px solid #1f2937';
            }

            // Update Colors/Glow
            document.getElementById('previewGlow').style.backgroundColor = data.color;
            document.getElementById('previewGlow').style.opacity = '0.1'; // slight tint
            
            // Checkmark color update
            const checkmark = document.querySelector('#paymentPreview .rounded-full');
            // Reset classes
            checkmark.className = `w-8 h-8 rounded-full border flex items-center justify-center relative z-10 shadow-[0_0_10px_${data.color}]`;
            checkmark.style.borderColor = data.color;
            checkmark.style.backgroundColor = `${data.color}33`; // 20% opacity hex
            checkmark.querySelector('span').style.color = data.color;
        }

        async function applyCoupon() {
            const code = document.getElementById('couponInput').value.trim().toUpperCase();
            const messageBox = document.getElementById('couponMessage');
            messageBox.innerHTML = '';
            messageBox.className = "mt-2 text-xs"; // reset class

            if (!code) {
                messageBox.innerHTML = 'Vui lòng nhập mã.';
                messageBox.classList.add('text-accent-red');
                return;
            }
            
            // Assuming we have the OrderId available in Model
            const orderId = '@Model.Id'; 
            
             try {
                // Using URLSearchParams to match the controller expectation
                const params = new URLSearchParams();
                params.append('code', code);
                params.append('orderId', orderId);

                const resp = await fetch('/ShoppingCart/ApplyCoupon', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params
                });
                
                const data = await resp.json();
                
                if (data.success) {
                    document.getElementById('discountAmount').innerText = formatCurrencyVND(data.discountAmount);
                    document.getElementById('finalTotal').innerText = formatCurrencyVND(data.finalTotal);
                    document.getElementById('discountSection').style.display = 'flex';
                    
                    messageBox.innerHTML = 'Áp dụng mã giảm giá thành công!';
                    messageBox.classList.add('text-green-500');
                } else {
                    document.getElementById('discountSection').style.display = 'none';
                    messageBox.innerHTML = data.message || 'Mã giảm giá không hợp lệ.';
                    messageBox.classList.add('text-accent-red');
                }
            } catch (err) {
                console.error(err);
                messageBox.innerHTML = 'Lỗi khi áp dụng mã giảm giá.';
                messageBox.classList.add('text-accent-red');
            }
        }
    </script>
}
