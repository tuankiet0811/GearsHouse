@{
    ViewData["Title"] = "Chi tiết ưu đãi sinh viên";
}

<!-- Định nghĩa CSS dải phân cách -->
<style>
    .custom-divider {
        border: none;
        height: 6px;
        background: linear-gradient(to right, #0d6efd, #6610f2, #6f42c1); /* xanh dương - tím */
        border-radius: 8px;
        margin: 3rem 0;
    }
</style>

<div class="container mt-5 mb-5">

    <!-- === Ưu đãi 1 === -->
    <h2 class="text-center text-uppercase text-primary mb-4 border-bottom pb-2">Ưu đãi MacBook cho Sinh viên</h2>

    <img src="~/image/sv1.webp" class="img-fluid mb-3" alt="Ưu đãi MacBook sinh viên">
    <h4 class="mt-4">1. Thời gian áp dụng:</h4>
    <p>01/06/2025 - 31/08/2025</p>
    <h4 class="mt-4">2. Nội dung ưu đãi:</h4>
    <ul>
        <li>Giảm 3% tối đa 500.000VNĐ cho sinh viên khi mua MacBook.</li>
        <li>Áp dụng khi có thẻ sinh viên hoặc email .edu.vn.</li>
        <li>Chỉ áp dụng tại hệ thống GEARHOUSE trên toàn quốc.</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Ưu đãi 2 === -->
    <h2 class="text-center text-uppercase text-danger mb-4 border-bottom pb-2">Ưu đãi iPad học tập</h2>

    <img src="~/image/sv2.webp" class="img-fluid mb-3" alt="Ưu đãi iPad sinh viên">
    <h4 class="mt-4">1. Thời gian áp dụng:</h4>
    <p>01/06/2025 - 31/08/2025</p>
    <ul>
        <li>Giảm 3% tối đa 500.000VNĐ cho iPad khi xuất trình thẻ sinh viên.</li>
        <li>Hỗ trợ trả góp 0% lãi suất qua MPOS.</li>
        <li>Miễn phí dán màn hình và tặng ốp bảo vệ.</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Ưu đãi 3 === -->
    <h2 class="text-center text-uppercase text-success mb-4 border-bottom pb-2">Ưu đãi điện thoại Samsung</h2>

    <img src="~/image/sv3.webp" class="img-fluid mb-3" alt="Ưu đãi Samsung sinh viên">
    <h4 class="mt-4">1. Thời gian:</h4>
    <p>01/06/2025 - 30/09/2025</p>
    <ul>
        <li>Giảm 6% tối đa 600.000VNĐ cho điện thoại Samsung dòng Galaxy A/S.</li>
        <li>Tặng tai nghe Bluetooth khi mua sản phẩm trên 7 triệu.</li>
        <li>Áp dụng cho sinh viên từ 18–25 tuổi, có giấy tờ xác minh.</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Ưu đãi 4 === -->
    <h2 class="text-center text-uppercase text-warning mb-4 border-bottom pb-2">Ưu đãi Laptop học online</h2>

    <img src="~/image/sv4.webp" class="img-fluid mb-3" alt="Ưu đãi Laptop sinh viên">
    <h4 class="mt-4">1. Thời gian:</h4>
    <p>15/06/2025 - 15/09/2025</p>
    <ul>
        <li>Giảm 3% tối đa 400.000VNĐ cho tất cả các dòng laptop học tập.</li>
        <li>Tặng kèm balo và chuột không dây GEARHOUSE.</li>
        <li>Hỗ trợ cài đặt phần mềm học tập miễn phí tại cửa hàng.</li>
    </ul>

</div>
