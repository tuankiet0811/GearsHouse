                <button id="tab-new" class="px-4 py-2 rounded-full border border-white/10 text-slate-400 hover:text-accent-cyan hover:border-accent-cyan/50 text-sm font-bold transition-colors">New Arrivals</button>
                <button id="tab-sale" class="px-4 py-2 rounded-full border border-white/10 text-slate-400 hover:text-accent-red hover:border-accent-red/50 text-sm font-bold transition-colors">On Sale</button>
            </div>
        </div>
        <div id="featured-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"></div>
    </div>
</section>
<script>
    const tabs = {
        best: document.getElementById('tab-best'),
        new: document.getElementById('tab-new'),
        sale: document.getElementById('tab-sale')
    };
    function setActive(mode){
        tabs.best.classList.remove('border-primary','bg-primary/10','text-primary');
        tabs.new.classList.remove('border-accent-cyan/50','text-accent-cyan');
        tabs.sale.classList.remove('border-accent-red/50','text-accent-red');
        if(mode==='best'){
            tabs.best.classList.add('border-primary','bg-primary/10','text-primary');
        }else if(mode==='new'){
            tabs.new.classList.add('border-accent-cyan/50','text-accent-cyan');
        }else{
            tabs.sale.classList.add('border-accent-red/50','text-accent-red');
        }
    }
    async function loadFeatured(mode){
        setActive(mode);
        const res = await fetch(`/Home/FeaturedProducts?mode=${mode}`);
        const items = await res.json();
        const data = items.slice(0,4);

        if (mode === 'sale' && data.length === 0) {
            document.getElementById('featured-grid').innerHTML = `
                <div class="col-span-full flex items-center justify-center h-[360px] rounded-2xl bg-surface-dark border border-white/10">
                    <p class="text-slate-400 text-sm font-bold">Chưa có sản phẩm nào có khuyến mãi</p>
                </div>
            `;
            return;
        }

        const cards = data.map(item => {
            const badge = mode==='best' ? {text:'BEST SELLER',cls:'from-primary to-blue-600 text-white',wrap:'bg-gradient-to-r'} :
                           mode==='new' ? {text:'NEW ARRIVAL',cls:'from-accent-cyan to-teal-500 text-white',wrap:'bg-gradient-to-r'} :
                           {text:`-${item.discountPercent ?? 0}% OFF`,cls:'from-accent-purple to-fuchsia-600 text-white',wrap:'bg-gradient-to-r'};
            const formatVND = (v) => Number(v).toLocaleString('vi-VN');
            const priceBlock = item.discountedPrice ? 
                `<div class="flex flex-col">
                    <span class="text-xs text-slate-500 line-through whitespace-nowrap">${formatVND(item.price)}&nbsp;₫</span>
                    <span class="text-xl font-bold text-white whitespace-nowrap">${formatVND(item.discountedPrice)}&nbsp;₫</span>
                 </div>` :
                `<span class="text-xl font-bold text-white whitespace-nowrap">${formatVND(item.price)}&nbsp;₫</span>`;
            const stockLabel = item.quantity > 0 ? 
                `<span class="text-xs text-accent-cyan font-bold border border-accent-cyan/30 px-2 py-0.5 rounded bg-accent-cyan/10">In Stock</span>` :
                `<span class="text-xs text-red-400 font-bold border border-red-400/30 px-2 py-0.5 rounded bg-red-900/30">Out of Stock</span>`;
            const avg = Number(item.ratingAverage) || 0;
            const cnt = Number(item.ratingCount) || 0;
            const full = Math.floor(avg);
            const half = avg - full >= 0.5;
            const empty = 5 - full - (half ? 1 : 0);
            let stars = '';
            for(let i=0;i<full;i++){ stars += `<span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1">star</span>`; }
            if(half){ stars += `<span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1">star_half</span>`; }
            for(let i=0;i<empty;i++){ stars += `<span class="material-symbols-outlined text-[16px]">star</span>`; }
            return `
            <div class="group flex flex-col bg-surface-light rounded-2xl overflow-hidden border border-white/5 hover:border-primary/50 hover:shadow-neon transition-all duration-300">
                <div class="relative w-full aspect-square bg-[#0f1115] p-6 flex items-center justify-center overflow-hidden">
                    <div class="absolute top-3 left-3 ${badge.wrap} ${badge.cls} text-xs font-bold px-3 py-1 rounded shadow-neon tracking-wider z-10">${badge.text}</div>
                    <img alt="${item.name}" class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105 z-0" src="${item.imageUrl ?? '/images/no-image.png'}" />
                    <a href="/Product/Display/${item.id}" class="absolute bottom-4 right-4 h-10 w-10 bg-primary rounded-full flex items-center justify-center text-white opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 shadow-neon hover:bg-white hover:text-primary">
                        <span class="material-symbols-outlined">visibility</span>
                    </a>
                </div>
                <div class="p-5 flex flex-col gap-2 flex-grow">
                    <div class="flex items-center gap-1 text-yellow-500 text-xs">${stars}<span class="text-slate-400 ml-1">${avg.toFixed(1)} (${cnt})</span></div>
                    <h3 class="text-white font-bold text-lg leading-tight group-hover:text-primary transition-colors">${item.name}</h3>
                    <div class="mt-auto pt-4 flex items-center justify-between">
                        ${priceBlock}
                        ${stockLabel}
                    </div>
                </div>
            </div>`;
        });
        for(let i = cards.length; i < 4; i++){
            cards.push(`<div class="group flex flex-col rounded-2xl overflow-hidden border border-transparent opacity-0 pointer-events-none"><div class="relative w-full aspect-square"></div></div>`);
        }
        document.getElementById('featured-grid').innerHTML = cards.join('');

        if (typeof gsap !== 'undefined') {
            gsap.killTweensOf("#featured-grid > div");
            gsap.set("#featured-grid > div", { opacity: 1, autoAlpha: 1, y: 0, clearProps: "all" });
            gsap.from("#featured-grid > div", {
                opacity: 0,
                y: 20,
                duration: 0.5,
                stagger: 0.08,
                ease: "power2.out",
                clearProps: "all"
            });
        }
    }
    tabs.best.addEventListener('click', ()=>loadFeatured('best'));
    tabs.new.addEventListener('click', ()=>loadFeatured('new'));
    tabs.sale.addEventListener('click', ()=>loadFeatured('sale'));
    loadFeatured('best');
</script>
<section class="py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-cyber-gradient opacity-20 animate-pulse"></div>
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-30"></div>
    <div class="layout-container mx-auto max-w-[1280px] px-4 md:px-6 relative z-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8 bg-surface-light/70 backdrop-blur-md border border-white/10 p-8 md:p-12 rounded-2xl shadow-neon-purple group hover:border-accent-purple/50 transition-colors duration-500">
            <div class="flex flex-col gap-4 text-center md:text-left max-w-xl">
                <span class="text-accent-cyan font-bold tracking-widest uppercase text-glow-cyan">Limited Time Offer</span>
                <h2 class="text-4xl md:text-6xl font-bold text-white leading-none text-glow-purple">GAMING SALE<br /><span class="text-3xl md:text-5xl text-transparent bg-clip-text bg-gradient-to-r from-accent-cyan via-white to-accent-red">UP TO 40% OFF</span></h2>
                <p class="text-slate-300 font-body">Upgrade your battlestation with premium gear at unbeatable prices. Offer ends soon.</p>
            </div>
            <div class="flex flex-col items-center gap-6">
                <div class="flex gap-4">
                    <div class="flex flex-col items-center bg-background-dark/80 p-3 rounded-lg border border-accent-cyan/30 shadow-[0_0_10px_rgba(6,182,212,0.2)] min-w-[70px]">
                        <span id="saleDays" class="text-2xl font-bold text-accent-cyan font-mono">--</span>
                        <span class="text-[10px] uppercase text-slate-400">Days</span>
                    </div>
                    <div class="text-2xl font-bold text-white self-start mt-2 animate-pulse">:</div>
                    <div class="flex flex-col items-center bg-background-dark/80 p-3 rounded-lg border border-accent-purple/30 shadow-[0_0_10px_rgba(168,85,247,0.2)] min-w-[70px]">
                        <span id="saleHours" class="text-2xl font-bold text-accent-purple font-mono">--</span>
                        <span class="text-[10px] uppercase text-slate-400">Hours</span>
                    </div>
                    <div class="text-2xl font-bold text-white self-start mt-2 animate-pulse">:</div>
                    <div class="flex flex-col items-center bg-background-dark/80 p-3 rounded-lg border border-accent-red/30 shadow-[0_0_10px_rgba(239,68,68,0.2)] min-w-[70px]">
                        <span id="saleMins" class="text-2xl font-bold text-accent-red font-mono">--</span>
                        <span class="text-[10px] uppercase text-slate-400">Mins</span>
                    </div>
                </div>
                <button class="w-full bg-white text-black hover:bg-slate-200 font-bold py-3 px-8 rounded shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-300 transform hover:scale-105 border-2 border-transparent hover:border-accent-purple">
                    Shop The Sale
                </button>
            </div>
        </div>
    </div>
</section>
<script>
    async function initSaleCountdown() {
        var d = document.getElementById('saleDays');
        var h = document.getElementById('saleHours');
        var m = document.getElementById('saleMins');
        try {
            var res = await fetch('/Home/NextFortySale');
            var info = await res.json();
            var target = info && info.target ? new Date(info.target) : null;
            function update() {
                var ms = target ? (target - new Date()) : 0;
                if (ms < 0) ms = 0;
                var days = Math.floor(ms / 86400000);
                var hours = Math.floor(ms / 3600000) % 24;
                var mins = Math.floor(ms / 60000) % 60;
                d.textContent = String(days).padStart(2, '0');
                h.textContent = String(hours).padStart(2, '0');
                m.textContent = String(mins).padStart(2, '0');
            }
            update();
            setInterval(update, 1000);
        } catch(e) {
            if (d) d.textContent = '00';
            if (h) h.textContent = '00';
            if (m) m.textContent = '00';
        }
    }
    document.addEventListener('DOMContentLoaded', initSaleCountdown);
</script>
<section class="py-16 bg-background-dark">
    <div class="layout-container mx-auto max-w-[1280px] px-4 md:px-6">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-white border-b-2 border-accent-red pb-1">Trending Now</h2>
            <div class="flex gap-2">
                <button id="trendingPrev" class="h-10 w-10 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-accent-red hover:border-accent-red hover:shadow-neon-red transition-colors">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button id="trendingNext" class="h-10 w-10 rounded-full border border-white/10 flex items-center justify-center text-white hover:bg-accent-red hover:border-accent-red hover:shadow-neon-red transition-colors">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>
        <div id="trending-strip" class="flex gap-6 overflow-x-auto hide-scrollbar pb-4 snap-x"></div>
    </div>
</section>
<script>
    async function loadTrending() {
        var strip = document.getElementById('trending-strip');
        var prev = document.getElementById('trendingPrev');
        var next = document.getElementById('trendingNext');
        var res = await fetch('/Home/TrendingProducts?count=12');
        var data = await res.json();
        var fmt = (v) => Number(v).toLocaleString('vi-VN');
        var html = data.map(p => `
            <div class="min-w-[280px] md:min-w-[320px] snap-center bg-surface-light rounded-xl p-4 border border-white/5 flex gap-4 items-center group hover:bg-surface-light/80 transition-all cursor-pointer">
                <div class="w-24 h-24 bg-[#0f1115] rounded-lg p-2 flex-shrink-0 border border-white/5 group-hover:border-accent-purple/30 transition-colors">
                    <img alt="${p.name}" class="w-full h-full object-contain" src="${p.imageUrl ?? '/images/no-image.png'}" />
                </div>
                <div class="flex flex-col">
                    <h4 class="text-white font-bold text-sm group-hover:text-accent-purple transition-colors">${p.name}</h4>
                    <p class="text-slate-500 text-xs">Premium Gear</p>
                    <span class="text-white font-bold mt-2 whitespace-nowrap">${fmt(p.discountedPrice ?? p.price)}&nbsp;₫</span>
                </div>
            </div>
        `).join('');
        strip.innerHTML = html;
        var step = 640;
        if (prev) prev.addEventListener('click', () => strip.scrollBy({ left: -step, behavior: 'smooth' }));
        if (next) next.addEventListener('click', () => strip.scrollBy({ left: step, behavior: 'smooth' }));
    }
    document.addEventListener('DOMContentLoaded', loadTrending);
</script>
