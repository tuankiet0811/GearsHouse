@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script>
        // Check if GSAP is loaded
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            // Hero Section
            const heroTl = gsap.timeline();
            heroTl.from("#hero h1", { autoAlpha: 0, y: 50, duration: 1, ease: "power3.out" })
                  .from("#hero h2", { autoAlpha: 0, y: 30, duration: 0.8, ease: "power3.out" }, "-=0.6")
                  .from("#hero button", { autoAlpha: 0, y: 20, duration: 0.8, stagger: 0.2, ease: "power3.out", clearProps: "all" }, "-=0.6")
                  .from("#hero .inline-flex", { autoAlpha: 0, y: -20, duration: 0.6, ease: "power2.out" }, "-=1.5");

            // Features Section
            gsap.from("#features .grid > div", {
                scrollTrigger: {
                    trigger: "#features",
                    start: "top 80%",
                },
                autoAlpha: 0,
                y: 30,
                duration: 0.8,
                stagger: 0.15,
                ease: "back.out(1.7)",
                clearProps: "all"
            });

            // Categories Section
            gsap.from("#categories h2, #categories .justify-between > a", {
                scrollTrigger: {
                    trigger: "#categories",
                    start: "top 85%",
                },
                autoAlpha: 0,
                x: -20,
                duration: 0.6,
                stagger: 0.1
            });

            gsap.from("#categories .grid > a", {
                scrollTrigger: {
                    trigger: "#categories .grid",
                    start: "top 80%",
                },
                autoAlpha: 0,
                scale: 0.9,
                duration: 0.6,
                stagger: 0.1,
                ease: "power2.out",
                clearProps: "all"
            });

            // Pro-Level Performance Section
            gsap.from("#pro-products h2, #pro-products p", {
                 scrollTrigger: {
                    trigger: "#pro-products",
                    start: "top 80%",
                },
                autoAlpha: 0,
                y: 20,
                duration: 0.8,
                stagger: 0.1
            });

            gsap.from("#pro-products .flex.gap-2 button", {
                 scrollTrigger: {
                    trigger: "#pro-products",
                    start: "top 80%",
                },
                autoAlpha: 0,
                x: 20,
                duration: 0.6,
                stagger: 0.1,
                clearProps: "all"
            });

            gsap.from("#pro-products .grid > div", {
                scrollTrigger: {
                    trigger: "#pro-products .grid",
                    start: "top 75%",
                },
                autoAlpha: 0,
                y: 50,
                duration: 0.8,
                stagger: 0.2,
                ease: "power3.out",
                clearProps: "all"
            });
        }
    </script>
}
