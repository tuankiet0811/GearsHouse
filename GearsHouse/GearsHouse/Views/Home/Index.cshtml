        </div>
        @{
            var allCategories = ViewBag.Categories as IEnumerable<Category> ?? new List<Category>();
            int GetCategoryId(string name)
            {
                // 1. Try exact match
                var cat = allCategories.FirstOrDefault(c => c.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
                if (cat != null) return cat.Id;

                // 2. Manual mappings (User defined)
                string targetName = "";
                if (name.Equals("Monitors", StringComparison.OrdinalIgnoreCase)) targetName = "Màn hình";
                else if (name.Equals("Mice", StringComparison.OrdinalIgnoreCase)) targetName = "Mouse";
                else if (name.Equals("Keyboards", StringComparison.OrdinalIgnoreCase)) targetName = "Bàn phím";
                else if (name.Equals("Headsets", StringComparison.OrdinalIgnoreCase)) targetName = "Tai nghe";
                else if (name.Equals("Chairs", StringComparison.OrdinalIgnoreCase)) targetName = "Ghế CTH/Gaming";
                else if (name.Equals("Parts", StringComparison.OrdinalIgnoreCase)) targetName = "Ram";

                if (!string.IsNullOrEmpty(targetName))
                {
                    cat = allCategories.FirstOrDefault(c => c.Name.Equals(targetName, StringComparison.OrdinalIgnoreCase));
                    if (cat != null) return cat.Id;
                    
                    // Fallback: Try contains if exact match fails
                    cat = allCategories.FirstOrDefault(c => c.Name.Contains(targetName, StringComparison.OrdinalIgnoreCase));
                    if (cat != null) return cat.Id;
                }

                // 3. Fallback: Try singular
                 if (name.EndsWith("s"))
                {
                    var singular = name.Substring(0, name.Length - 1);
                    cat = allCategories.FirstOrDefault(c => c.Name.Equals(singular, StringComparison.OrdinalIgnoreCase));
                    if (cat != null) return cat.Id;
                }

                return 0;
            }
        }
