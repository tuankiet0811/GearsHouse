@model List<GearsHouse.Models.ChatDashboardViewModel>
@{
    Layout = null;
}

<div class="flex h-[calc(100vh-140px)] gap-6 p-1">
    <!-- Thread List Sidebar -->
    <div class="w-1/3 flex flex-col rounded-2xl border border-white/5 bg-[#1c232b]/80 backdrop-blur-xl overflow-hidden shadow-2xl gsap-fade-up">
        <!-- Sidebar Header -->
        <div class="p-6 border-b border-white/5 bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-md">
            <h3 class="font-bold text-white text-xl tracking-tight flex items-center gap-3">
                <div class="p-2 rounded-lg bg-gradient-to-br from-blue-500/20 to-purple-500/20 border border-blue-500/20 shadow-[0_0_15px_rgba(59,130,246,0.15)]">
                    <span class="material-symbols-outlined text-blue-400">forum</span>
                </div>
                <span>Tin Nhắn</span>
            </h3>
        </div>

        <!-- Thread List -->
        <div class="flex-1 overflow-y-auto p-3 space-y-2 custom-scrollbar" id="threadList">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="thread-item group cursor-pointer p-4 rounded-xl hover:bg-white/5 transition-all border border-transparent hover:border-blue-500/30 relative overflow-hidden" 
                         data-thread="@item.Thread.Id"
                         data-name="@(item.Customer?.FullName ?? "Khách Hàng")"
                         data-customer-id="@(item.Customer?.Id ?? item.Thread.CustomerId)">
                        
                        <!-- Hover Gradient Effect -->
                        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/0 via-blue-500/0 to-blue-500/0 group-hover:from-blue-500/5 group-hover:via-purple-500/5 group-hover:to-transparent transition-all duration-500"></div>

                        <div class="relative flex items-center gap-4">
                            <!-- Avatar -->
                            <div class="relative">
                                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#2a303c] to-[#1a1f26] border border-white/10 flex items-center justify-center shadow-lg group-hover:shadow-blue-500/20 transition-all">
                                    <span class="font-bold text-lg text-gray-400 group-hover:text-white transition-colors">
                                        @(item.Customer?.FullName?.Substring(0, 1).ToUpper() ?? "C")
                                    </span>
                                </div>
                                @if (item.UnreadCount > 0)
                                {
                                    <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-red-500 border-2 border-[#1c232b] flex items-center justify-center shadow-lg shadow-red-500/40 animate-pulse">
                                        <span class="text-[10px] font-bold text-white">@item.UnreadCount</span>
                                    </div>
                                }
                            </div>

                            <!-- Info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-start mb-0.5">
                                    <h4 class="font-bold text-gray-200 truncate group-hover:text-blue-400 transition-colors text-base">
                                        @(item.Customer?.FullName ?? "Unknown Customer")
                                    </h4>
                                    <span class="text-[10px] text-gray-500 whitespace-nowrap ml-2">
                                        @if(item.Thread.Messages.Any())
                                        {
                                            @item.Thread.Messages.Last().CreatedAt.ToString("HH:mm")
                                        }
                                    </span>
                                </div>
                                
                                <div class="flex flex-col gap-1">
                                    <span class="text-[11px] font-mono text-gray-500 truncate group-hover:text-gray-400 transition-colors flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[12px] opacity-70">fingerprint</span>
                                        ID: @(item.Customer?.Id ?? item.Thread.CustomerId)
                                    </span>
                                    
                                    <div class="flex items-center justify-between">
                                        <span class="text-[10px] px-2 py-0.5 rounded-md font-bold uppercase tracking-wider @(item.Thread.IsClosed ? "bg-gray-500/10 text-gray-500 border border-gray-500/10" : "bg-green-500/10 text-green-400 border border-green-500/10 shadow-[0_0_10px_rgba(34,197,94,0.1)]")">
                                            @(item.Thread.IsClosed ? "Đã Đóng" : "Đang Hoạt Động")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="flex flex-col items-center justify-center h-64 text-gray-500">
                    <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-3xl opacity-50">inbox</span>
                    </div>
                    <p class="text-sm font-medium">No conversations yet</p>
                </div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="flex-1 flex flex-col rounded-2xl border border-white/5 bg-[#1c232b]/80 backdrop-blur-xl overflow-hidden shadow-2xl relative gsap-fade-up">
        <!-- Chat Header -->
        <div id="chatHeader" class="hidden p-4 border-b border-white/5 bg-[#1c232b]/95 backdrop-blur-md flex justify-between items-center z-20 shadow-lg shadow-black/20">
            <div class="flex items-center gap-4">
                 <div class="w-11 h-11 rounded-full bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center shadow-lg shadow-blue-500/20 border border-white/10">
                    <span class="material-symbols-outlined text-white text-xl">person</span>
                </div>
                <div>
                    <h3 class="font-bold text-white text-lg leading-tight tracking-tight" id="headerName">Chọn một cuộc trò chuyện</h3>
                    <div class="flex items-center gap-2 mt-0.5">
                        <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
                        <p class="text-xs text-gray-400 font-mono" id="headerId"></p>
                    </div>
                </div>
            </div>
            <button class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/10 transition-all">
                <span class="material-symbols-outlined">more_vert</span>
            </button>
        </div>

        <!-- Messages Container -->
        <div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar relative bg-[#0f1216]/50" id="chatMessages">
             <div class="absolute inset-0 bg-cyber-grid opacity-10 pointer-events-none"></div>
             
             <!-- Empty State -->
             <div class="flex h-full items-center justify-center text-gray-500 flex-col gap-6" id="emptyState">
                <div class="relative group">
                    <div class="absolute inset-0 bg-blue-500/20 rounded-full blur-xl group-hover:bg-blue-500/30 transition-all duration-500"></div>
                    <div class="relative w-24 h-24 rounded-full bg-[#1c232b] border border-white/10 flex items-center justify-center shadow-2xl">
                        <span class="material-symbols-outlined text-5xl text-blue-400/80">forum</span>
                    </div>
                </div>
                <div class="text-center space-y-2">
                    <h3 class="text-xl font-bold text-white tracking-tight">Trung Tâm Hỗ Trợ</h3>
                    <p class="text-sm text-gray-400 max-w-xs mx-auto">Chọn một cuộc trò chuyện từ danh sách bên trái để bắt đầu nhắn tin với khách hàng.</p>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-5 bg-[#1c232b] border-t border-white/5 z-20">
            <div class="flex gap-4 items-end">
                <div class="flex-1 bg-[#0f1216] border border-white/10 rounded-2xl p-1.5 transition-all focus-within:border-blue-500/50 focus-within:shadow-[0_0_20px_rgba(59,130,246,0.1)] focus-within:bg-[#0f1216]/80">
                    <textarea id="chatInput" rows="1" class="w-full bg-transparent border-0 text-white placeholder-gray-600 focus:ring-0 resize-none py-3 px-4 text-sm max-h-32 min-h-[46px] leading-relaxed" placeholder="Nhập tin nhắn..." disabled></textarea>
                </div>
                <button id="chatSend" class="h-[56px] w-[56px] rounded-2xl bg-gradient-to-br from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white shadow-lg shadow-blue-500/20 hover:shadow-blue-500/40 hover:scale-105 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 flex items-center justify-center group" disabled>
                    <span class="material-symbols-outlined text-2xl group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">send</span>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }
</style>

<script>
    // Initialize GSAP for Chat Dashboard
    // Animation removed to prevent visibility issues
    /*
    if (typeof gsap !== 'undefined') {
        gsap.from(".thread-item", {
            duration: 0.5, 
            opacity: 0, 
            x: -20, 
            stagger: 0.1, 
            ease: "power2.out",
            delay: 0.2
        });
    }
    */

    let currentThreadId = null;
    let pollInterval = null;

    document.querySelectorAll('.thread-item').forEach(item => {
        item.addEventListener('click', function() {
            // Update active state
            document.querySelectorAll('.thread-item').forEach(t => {
                t.classList.remove('bg-blue-500/10', 'border-blue-500/30');
                t.querySelector('.absolute.inset-0').classList.remove('opacity-100'); // Helper to reset gradient if needed
            });
            this.classList.add('bg-blue-500/10', 'border-blue-500/30');
            
            // Get info
            currentThreadId = this.getAttribute('data-thread');
            const name = this.getAttribute('data-name');
            const id = this.getAttribute('data-customer-id');

            // Update Header
            document.getElementById('emptyState').classList.add('hidden');
            const header = document.getElementById('chatHeader');
            header.classList.remove('hidden');
            header.classList.add('flex'); // Ensure flex display
            
            document.getElementById('headerName').textContent = name;
            document.getElementById('headerId').textContent = 'ID: ' + id;

            // Enable Input
            const input = document.getElementById('chatInput');
            const sendBtn = document.getElementById('chatSend');
            input.disabled = false;
            sendBtn.disabled = false;
            input.focus();

            // Load messages
            loadMessages();
            if(pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(loadMessages, 3000);
            
            // Mark as read in UI (remove badge)
            const badge = this.querySelector('.bg-red-500');
            if(badge) badge.remove();
        });
    });

    function loadMessages() {
        if(!currentThreadId) return;
        
        // Get last message id to append? simplified: just reload for now or check if we want incremental
        // The controller supports afterId. For simplicity in this turn, I'll reload all 200.
        // Optimization: In real app, keep track of lastId.
        
        fetch('/Chat/Messages?threadId=' + currentThreadId)
            .then(res => res.json())
            .then(data => {
                const container = document.getElementById('chatMessages');
                // Don't clear if appending, but here we replace for simplicity or need diffing
                // Simple implementation: clear everything except bg
                const bg = container.querySelector('.absolute');
                container.innerHTML = '';
                container.appendChild(bg);
                
                data.forEach(msg => {
                    const isStaff = msg.isStaff;
                    const div = document.createElement('div');
                    div.className = `flex ${isStaff ? 'justify-end' : 'justify-start'} mb-4 animate-fadeIn`;
                    
                    // Styling
                    const bubbleClass = isStaff 
                        ? 'bg-gradient-to-br from-blue-600 to-blue-500 text-white rounded-2xl rounded-tr-none shadow-lg shadow-blue-500/20' 
                        : 'bg-[#2a303c] border border-white/5 text-gray-200 rounded-2xl rounded-tl-none shadow-md';
                        
                    div.innerHTML = `
                        <div class="max-w-[75%] ${bubbleClass} px-5 py-3 relative group">
                            <p class="text-sm leading-relaxed">${escapeHtml(msg.content)}</p>
                            <span class="text-[10px] ${isStaff ? 'text-blue-100/70' : 'text-gray-500'} mt-1 block text-right font-mono">
                                ${msg.at}
                            </span>
                        </div>
                    `;
                    container.appendChild(div);
                });
                
                // Scroll to bottom
                container.scrollTop = container.scrollHeight;
            });
    }

    document.getElementById('chatSend').addEventListener('click', sendMessage);
    document.getElementById('chatInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    function sendMessage() {
        if(!currentThreadId) return;
        const input = document.getElementById('chatInput');
        const content = input.value.trim();
        if(!content) return;

        fetch('/Chat/Send', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: new URLSearchParams({
                threadId: currentThreadId,
                content: content
            })
        })
        .then(res => res.json())
        .then(data => {
            input.value = '';
            loadMessages();
        });
    }

    function escapeHtml(text) {
        if (!text) return text;
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Auto-resize textarea
    const textarea = document.getElementById('chatInput');
    textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
    });
</script>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out forwards;
    }
</style>