@model GearsHouse.Models.Order
@using GearsHouse.Extensions
@using GearsHouse.Helpers

<div class="bg-[#1a2027] border border-[#283039] rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh] w-full">
    <!-- Header -->
    <div class="p-6 border-b border-[#283039] flex justify-between items-center bg-[#1c232b]">
        <div class="flex items-center gap-4">
            <div class="p-3 rounded-xl bg-gradient-to-br from-blue-500/20 to-purple-500/20 border border-blue-500/20 text-primary shadow-[0_0_15px_rgba(59,130,246,0.15)]">
                <span class="material-symbols-outlined text-2xl">receipt_long</span>
            </div>
            <div>
                <h3 class="text-xl font-bold text-white tracking-tight">Chi Tiết Đơn Hàng</h3>
                <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-sm text-slate-400 font-mono bg-[#111418] px-2 py-0.5 rounded border border-[#283039]">#ORD-@Model.Id</span>
                    <span class="text-xs text-slate-500">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>
        <button onclick="closeOrderDetailModal()" class="group p-2 rounded-lg text-slate-400 hover:text-white hover:bg-[#283039] transition-all duration-300">
            <span class="material-symbols-outlined group-hover:rotate-90 transition-transform duration-300">close</span>
        </button>
    </div>

    <!-- Scrollable Content -->
    <div class="overflow-y-auto p-6 space-y-6 custom-scrollbar bg-[#111418]/50">
        <!-- Status Bar -->
        <div class="flex flex-wrap gap-4 items-center p-4 rounded-xl bg-[#1c232b]/50 border border-[#283039] backdrop-blur-sm">
            <span class="text-slate-400 text-sm font-medium">Trạng thái hiện tại:</span>
            @{
                var statusClass = "bg-slate-500/10 text-slate-400 border-slate-500/20";
                var dotClass = "bg-slate-400";
                var statusText = Model.OrderStatus.ToString();
                
                switch (Model.OrderStatus)
                {
                    case GearsHouse.Models.OrderStatus.ChoXacNhan:
                        statusClass = "bg-yellow-500/10 text-yellow-400 border-yellow-500/20 shadow-[0_0_10px_rgba(234,179,8,0.1)]";
                        dotClass = "bg-yellow-400";
                        statusText = "Chờ Xác Nhận";
                        break;
                    case GearsHouse.Models.OrderStatus.DangXuLy:
                        statusClass = "bg-blue-500/10 text-blue-400 border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.1)]";
                        dotClass = "bg-blue-400";
                        statusText = "Đang Xử Lý";
                        break;
                    case GearsHouse.Models.OrderStatus.DangGiaoHang:
                        statusClass = "bg-indigo-500/10 text-indigo-400 border-indigo-500/20 shadow-[0_0_10px_rgba(99,102,241,0.1)]";
                        dotClass = "bg-indigo-400";
                        statusText = "Đang Giao Hàng";
                        break;
                    case GearsHouse.Models.OrderStatus.HoanThanh:
                        statusClass = "bg-green-500/10 text-green-400 border-green-500/20 shadow-[0_0_10px_rgba(34,197,94,0.1)]";
                        dotClass = "bg-green-400";
                        statusText = "Hoàn Thành";
                        break;
                    case GearsHouse.Models.OrderStatus.DaHuy:
                        statusClass = "bg-red-500/10 text-red-400 border-red-500/20 shadow-[0_0_10px_rgba(248,113,113,0.1)]";
                        dotClass = "bg-red-400";
                        statusText = "Đã Hủy";
                        break;
                }
            }
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-bold @statusClass border transition-all hover:scale-105">
                <span class="size-2 rounded-full @dotClass animate-pulse"></span>
                @statusText
            </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Customer Info -->
            <div class="space-y-3 gsap-fade-up">
                <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider flex items-center gap-2 pl-1">
                    <span class="material-symbols-outlined text-[18px]">person</span>
                    Thông tin khách hàng
                </h4>
                <div class="p-5 rounded-xl bg-[#1c232b] border border-[#283039] space-y-4 hover:border-primary/30 transition-colors group">
                    <div class="flex items-start gap-4">
                        <div class="size-10 rounded-full bg-[#111418] flex items-center justify-center text-slate-400 border border-[#283039] group-hover:border-primary/30 group-hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">badge</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-xs text-slate-500 block mb-0.5">Họ và tên</span>
                            <span class="text-white font-medium">@Model.FullName</span>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="size-10 rounded-full bg-[#111418] flex items-center justify-center text-slate-400 border border-[#283039] group-hover:border-primary/30 group-hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">call</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-xs text-slate-500 block mb-0.5">Số điện thoại</span>
                            <span class="text-white font-medium font-mono">@Model.PhoneNumber</span>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4 pt-2 border-t border-[#283039]/50">
                        <div class="size-10 rounded-full bg-[#111418] flex items-center justify-center text-slate-400 border border-[#283039] group-hover:border-primary/30 group-hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">local_shipping</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-xs text-slate-500 block mb-0.5">Địa chỉ giao hàng</span>
                            <span class="text-white font-medium leading-relaxed">@Model.ShippingAddress</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Info -->
            <div class="space-y-3">
                <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider flex items-center gap-2 pl-1">
                    <span class="material-symbols-outlined text-[18px]">info</span>
                    Thanh toán & Ghi chú
                </h4>
                <div class="p-5 rounded-xl bg-[#1c232b] border border-[#283039] space-y-4 hover:border-primary/30 transition-colors group">
                    <div class="flex items-start gap-4">
                        <div class="size-10 rounded-full bg-[#111418] flex items-center justify-center text-slate-400 border border-[#283039] group-hover:border-primary/30 group-hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">payments</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-xs text-slate-500 block mb-0.5">Phương thức thanh toán</span>
                            <span class="text-white font-medium">@Model.PaymentMethod</span>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4 pt-2 border-t border-[#283039]/50">
                        <div class="size-10 rounded-full bg-[#111418] flex items-center justify-center text-slate-400 border border-[#283039] group-hover:border-primary/30 group-hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">description</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-xs text-slate-500 block mb-0.5">Ghi chú đơn hàng</span>
                            <span class="text-white font-medium leading-relaxed italic text-sm">
                                @(string.IsNullOrEmpty(Model.Notes) ? "Khách hàng không có ghi chú thêm." : Model.Notes)
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products -->
        <div class="space-y-3 gsap-fade-up">
            <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider flex items-center gap-2 pl-1">
                <span class="material-symbols-outlined text-[18px]">inventory_2</span>
                Sản phẩm đặt mua (@Model.OrderDetails.Sum(x => x.Quantity))
            </h4>
            <div class="rounded-xl border border-[#283039] overflow-hidden bg-[#1c232b] shadow-lg">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-[#111418] text-xs text-slate-400 uppercase tracking-wider border-b border-[#283039]">
                            <th class="p-4 font-bold">Tên sản phẩm</th>
                            <th class="p-4 font-bold text-right">Đơn giá</th>
                            <th class="p-4 font-bold text-center">SL</th>
                            <th class="p-4 font-bold text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-[#283039]">
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr class="hover:bg-[#283039]/50 transition-colors group">
                                <td class="p-4">
                                    <div class="font-medium text-white group-hover:text-primary transition-colors">@item.Product?.Name</div>
                                    <div class="text-xs text-slate-500 mt-1">ID: #@item.ProductId</div>
                                </td>
                                <td class="p-4 text-slate-400 text-right font-mono">@item.Price.ToString("N0")</td>
                                <td class="p-4 text-white text-center font-bold">
                                    <span class="bg-[#111418] border border-[#283039] px-2 py-1 rounded text-xs">x @item.Quantity</span>
                                </td>
                                <td class="p-4 text-white font-bold text-right font-mono">@((item.Price * item.Quantity).ToString("N0"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-[#111418] border-t border-[#283039]">
                        <tr>
                            <td colspan="3" class="p-5 text-right text-slate-400 font-bold uppercase tracking-wider text-xs">Tổng cộng</td>
                            <td class="p-5 text-right">
                                <span class="text-2xl font-black text-primary drop-shadow-[0_0_10px_rgba(59,130,246,0.3)]">@Model.TotalPrice.ToString("N0") <span class="text-sm font-normal text-slate-400">VNĐ</span></span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Footer -->
    <div class="p-6 border-t border-[#283039] bg-[#1c232b] flex justify-end">
        <button onclick="closeOrderDetailModal()" class="px-6 py-2.5 rounded-lg bg-[#283039] text-white font-bold hover:bg-[#3b4754] hover:text-white border border-[#3b4754] hover:border-slate-500 transition-all flex items-center gap-2 shadow-lg">
            Đóng chi tiết
        </button>
    </div>
</div>