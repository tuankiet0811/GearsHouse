@model GearsHouse.Models.Promotion

<div class="w-full max-w-2xl mx-auto">
    <!-- Main Card -->
    <div class="bg-[#1a2027] border border-[#283039] rounded-2xl shadow-2xl overflow-hidden relative group/card gsap-fade-up">
        
        <!-- Ambient Glow Background -->
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-secondary/10 rounded-full blur-3xl pointer-events-none"></div>

        <!-- Header Section -->
        <div class="relative p-8 pb-6 border-b border-[#283039] bg-[#1a2027]/50 backdrop-blur-sm">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight flex items-center gap-3">
                        <span class="p-2 rounded-lg bg-gradient-to-br from-primary to-primary/50 text-white shadow-lg shadow-primary/20">
                            <span class="material-symbols-outlined">campaign</span>
                        </span>
                        Tạo Chiến Dịch
                    </h2>
                    <p class="mt-1 text-[#9cabba] text-sm">Tạo sự kiện giảm giá mới cho sản phẩm của bạn.</p>
                </div>
                <button type="button" onclick="closeCreateModal()" class="text-[#9cabba] hover:text-white transition-colors p-2 rounded-lg hover:bg-[#283039]">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
        </div>

        <!-- Form Section -->
        <form asp-action="Create" method="post" onsubmit="return submitCreateForm(event)" class="p-8 space-y-8 relative z-10">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="bg-red-500/10 border border-red-500/20 text-red-500 rounded-lg p-4 text-sm font-medium"></div>

            <!-- Product Selection -->
            <div class="space-y-3 group/field">
                <label asp-for="ProductId" class="text-sm font-semibold text-[#9cabba] group-focus-within/field:text-primary transition-colors flex items-center gap-2">
                    Sản Phẩm Mục Tiêu <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-[#9cabba] group-focus-within/field:text-primary transition-colors">inventory_2</span>
                    </div>
                    <select asp-for="ProductId" asp-items="ViewBag.Products" class="w-full bg-[#111418] border border-[#3b4754] text-white text-sm rounded-xl pl-12 pr-10 py-4 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary focus:shadow-[0_0_15px_rgba(168,85,247,0.15)] transition-all appearance-none cursor-pointer hover:border-[#9cabba]/50">
                        <option disabled="" selected="" value="">Chọn sản phẩm để khuyến mãi...</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-[#9cabba]">expand_more</span>
                    </div>
                </div>
                <span asp-validation-for="ProductId" class="text-red-500 text-xs"></span>
            </div>

            <!-- Discount & Timeline Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Discount -->
                <div class="space-y-3 group/field">
                    <label asp-for="DiscountPercent" class="text-sm font-semibold text-[#9cabba] group-focus-within/field:text-secondary transition-colors flex items-center gap-2">
                        Giảm Giá <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="DiscountPercent" type="number" min="0" max="100" class="w-full bg-[#111418] border border-[#3b4754] text-white text-lg font-bold rounded-xl pl-4 pr-12 py-4 focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary focus:shadow-[0_0_15px_rgba(59,130,246,0.15)] transition-all placeholder-[#3b4754]" placeholder="0" />
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                            <span class="text-secondary font-bold text-lg">%</span>
                        </div>
                    </div>
                    <span asp-validation-for="DiscountPercent" class="text-red-500 text-xs"></span>
                </div>

                <!-- Start Date -->
                <div class="space-y-3 group/field">
                    <label asp-for="StartDate" class="text-sm font-semibold text-[#9cabba] group-focus-within/field:text-accent-green transition-colors flex items-center gap-2">
                        Ngày Bắt Đầu <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-[#9cabba] group-focus-within/field:text-accent-green transition-colors">calendar_today</span>
                        </div>
                        <input asp-for="StartDate" type="date" class="w-full bg-[#111418] border border-[#3b4754] text-white text-sm rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-accent-green focus:ring-1 focus:ring-accent-green focus:shadow-[0_0_15px_rgba(34,197,94,0.15)] transition-all [color-scheme:dark]" />
                    </div>
                    <span asp-validation-for="StartDate" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- End Date (Full Width for emphasis on duration) -->
            <div class="space-y-3 group/field">
                <label asp-for="EndDate" class="text-sm font-semibold text-[#9cabba] group-focus-within/field:text-accent-red transition-colors flex items-center gap-2">
                    Ngày Kết Thúc <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-[#9cabba] group-focus-within/field:text-accent-red transition-colors">event_busy</span>
                    </div>
                    <input asp-for="EndDate" type="date" class="w-full bg-[#111418] border border-[#3b4754] text-white text-sm rounded-xl pl-12 pr-4 py-4 focus:outline-none focus:border-accent-red focus:ring-1 focus:ring-accent-red focus:shadow-[0_0_15px_rgba(239,68,68,0.15)] transition-all [color-scheme:dark]" />
                </div>
                <span asp-validation-for="EndDate" class="text-red-500 text-xs"></span>
            </div>

            <!-- Footer Actions -->
            <div class="pt-6 mt-6 border-t border-[#283039] flex items-center justify-end gap-4">
                <button type="button" onclick="closeCreateModal()" class="px-6 py-3 rounded-xl border border-[#3b4754] text-[#9cabba] font-semibold hover:bg-[#283039] hover:text-white hover:border-[#9cabba] transition-all duration-200">
                    Hủy
                </button>
                <button type="submit" class="px-8 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-bold shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 flex items-center gap-2">
                    <span class="material-symbols-outlined">rocket_launch</span>
                    Tạo Chiến Dịch
                </button>
            </div>
        </form>
    </div>
</div>
