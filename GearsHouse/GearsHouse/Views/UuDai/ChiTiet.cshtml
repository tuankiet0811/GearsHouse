@{
    ViewData["Title"] = "Chi tiết khuyến mãi";
}

<!-- Định nghĩa CSS dải phân cách -->
<style>
    .custom-divider {
        border: none;
        height: 6px;
        background: linear-gradient(to right, #dc3545, #fd7e14, #ffc107); /* đỏ - cam - vàng */
        border-radius: 8px;
        margin: 3rem 0;
    }
</style>

<div class="container mt-5 mb-5">

    <!-- === Khuyến mãi 1 === -->
    <h2 class="text-center text-uppercase text-danger mb-4 border-bottom pb-2">Khuyến mãi iPhone 16e cùng HSBC</h2>

    <img src="~/image/tt1.webp" class="img-fluid mb-3" alt="Khuyến mãi iPhone 16e">
    <h4 class="mt-4">1. Thời gian chương trình:</h4>
    <p>01/04/2025 - 31/05/2025</p>
    <h4 class="mt-4">2. Nội dung Chương Trình:</h4>
    <ul>
        <li>Khách hàng mua hàng tại GEARHOUSE và thanh toán bằng thẻ tín dụng HSBC được giảm 500.000VNĐ cho iPhone 16e.</li>
        <li>Số lượng ưu đãi: 200 suất (chia 2 giai đoạn).</li>
        <li>Áp dụng 1 lần duy nhất mỗi tài khoản.</li>
        <li>Chỉ áp dụng khi thanh toán 100% bằng thẻ HSBC tại cửa hàng GEARHOUSE.</li>
        <li>Không áp dụng đồng thời với ví điện tử hoặc ngân hàng khác.</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Khuyến mãi 2 === -->
    <h2 class="text-center text-uppercase text-primary mb-4 border-bottom pb-2">Ưu đãi thanh toán qua Kredivo</h2>

    <img src="~/image/tt2.webp" class="img-fluid mb-3" alt="Ưu đãi Kredivo">
    <h5>1. Dành cho người dùng mới:</h5>
    <ul>
        <li>Giảm 50% (tối đa 250K) khi mua tại GEARHOUSE.</li>
        <li>Áp dụng với kỳ hạn 30 ngày, 3/6/12 tháng.</li>
        <li>Voucher chỉ dùng 1 lần, không áp dụng lại nếu đơn bị hủy.</li>
    </ul>
    <h5>2. Dành cho người dùng Kredivo hiện tại:</h5>
    <ul>
        <li>Giảm 7% (tối đa 500K) cho đơn từ 700K.</li>
        <li>Áp dụng kỳ hạn trả góp 6/12 tháng.</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Khuyến mãi 3 === -->
    <h2 class="text-center text-uppercase text-success mb-4 border-bottom pb-2">Ưu đãi Visa Sacombank qua MPOS</h2>

    <img src="~/image/tt3.webp" class="img-fluid mb-3" alt="Ưu đãi Sacombank">
    <p><strong>Thời gian:</strong> 25/02/2025 - 24/06/2025</p>
    <h5>Chương trình 1:</h5>
    <ul>
        <li>Đơn 3–10 triệu: giảm 400K</li>
        <li>Đơn 10–20 triệu: giảm 600K</li>
        <li>Trên 20 triệu: giảm 1 triệu</li>
    </ul>
    <h5>Chương trình 2 (hết suất Chương trình 1):</h5>
    <ul>
        <li>Đơn từ 3 triệu: giảm 200K</li>
    </ul>

    <hr class="custom-divider" />

    <!-- === Khuyến mãi 4 === -->
    <h2 class="text-center text-uppercase text-warning mb-4 border-bottom pb-2">Ưu đãi thẻ tín dụng Vietbank</h2>

    <img src="~/image/tt4.webp" class="img-fluid mb-3" alt="Ưu đãi Vietbank">
    <p><strong>Thời gian:</strong> 04/04/2025 - 31/12/2025</p>
    <ul>
        <li>Đơn từ 10 triệu: giảm 500K</li>
        <li>Đơn từ 20 triệu: giảm 1 triệu</li>
        <li>Áp dụng 1 lần mỗi tài khoản, tại GEARHOUSE toàn quốc.</li>
        <li>Áp dụng kèm Trả góp 0% (qua MPOS).</li>
        <li>Không áp dụng cùng ưu đãi ngân hàng khác.</li>
    </ul>

</div>
